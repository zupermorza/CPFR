########################

def apply_fallback_logic(fact_kpi: pd.DataFrame, f_season: pd.DataFrame) -> pd.DataFrame:
    """
    For items with low_history_flag=1:
    - Join store-subcategory seasonal weights
    - Compute store_subcategory_weight (allocation proxy)
    - Flag used_subcategory_proxy (for explainability)
    """
    print("\n[APPLYING FALLBACK LOGIC]")

    if "low_history_flag" not in fact_kpi.columns:
        fact_kpi["low_history_flag"] = 0

    low_history_items = fact_kpi[fact_kpi["low_history_flag"] == 1].copy()

    # Defaults
    fact_kpi["store_subcategory_weight"] = fact_kpi.get("store_subcategory_weight", 0)
    fact_kpi["used_subcategory_proxy"] = 0

    if low_history_items.empty:
        print("  No low-history items requiring fallback")
        return fact_kpi

    print(f"  Processing {len(low_history_items):,} low-history store-items")

    if f_season is None or f_season.empty or "subcategory" not in f_season.columns:
        print("  ⚠️  F_STORE_SUBCATEGORY_SEASON not available for fallback")
        return fact_kpi

    # Aggregate seasonal by store-subcategory
    season_agg = f_season.groupby(["store_id", "subcategory"], as_index=False).agg({"seasonal_sellout_units": "sum"})
    subcat_totals = (
        season_agg.groupby("subcategory", as_index=False)
        .agg({"seasonal_sellout_units": "sum"})
        .rename(columns={"seasonal_sellout_units": "subcat_total"})
    )

    season_agg = safe_merge(season_agg, subcat_totals, on=["subcategory"], how="left")
    season_agg["store_subcategory_weight"] = np.where(
        season_agg["subcat_total"] > 0, season_agg["seasonal_sellout_units"] / season_agg["subcat_total"], 0
    )

    # Join weights to low history items
    low_history_items = safe_merge(
        low_history_items,
        season_agg[["store_id", "subcategory", "store_subcategory_weight"]],
        on=["store_id", "subcategory"],
        how="left",
    )
    low_history_items["store_subcategory_weight"] = low_history_items["store_subcategory_weight"].fillna(0)

    # Merge back to main fact (store-item level)
    fact_kpi = fact_kpi.merge(
        low_history_items[["store_id", "client_item_nbr", "store_subcategory_weight"]],
        on=["store_id", "client_item_nbr"],
        how="left",
        suffixes=("", "_new"),
    )

    # Prefer new weight where available
    if "store_subcategory_weight_new" in fact_kpi.columns:
        fact_kpi["store_subcategory_weight"] = np.where(
            fact_kpi["store_subcategory_weight_new"].notna(),
            fact_kpi["store_subcategory_weight_new"],
            fact_kpi["store_subcategory_weight"],
        )
        fact_kpi.drop(columns=["store_subcategory_weight_new"], inplace=True, errors="ignore")

    fact_kpi["store_subcategory_weight"] = fact_kpi["store_subcategory_weight"].fillna(0)
    fact_kpi["used_subcategory_proxy"] = np.where(
        (fact_kpi["low_history_flag"] == 1) & (fact_kpi["store_subcategory_weight"] > 0), 1, 0
    )

    print(f"  ✓ Assigned subcategory weights to {(fact_kpi['store_subcategory_weight'] > 0).sum():,} items")
    return fact_kpi

