    print(f"    Duplicates (store-item): {f_current.duplicated(subset=['store_id','client_item_nbr']).sum()}")
    print(f"    week_id (analysis): {current_week_id}")

    print("\n  F_STORE_SUBCATEGORY_SEASON:")
    print(f"    Rows: {len(f_season):,}")

    print("\n  F_ACTIVE_STORE_ITEM (MANDATORY FILTER):")
    print(f"    Active combinations: {len(f_active):,}")
    print(f"    Duplicates: {f_active.duplicated(subset=['store_id','client_item_nbr']).sum()}")

    # Catalog coverage
    print("\n  Catalog Coverage:")

    # Stores
    current_stores = set(f_current["store_id"].unique())
    catalog_stores = set(dim_store["store_id"].unique())
    store_match = len(current_stores & catalog_stores)
    store_pct = (store_match / len(current_stores) * 100) if len(current_stores) > 0 else 0
    print(f"    Stores: {store_pct:.1f}% ({store_match:,}/{len(current_stores):,})")
    if len(current_stores - catalog_stores) > 0:
        print(f"    ⚠️  Unmatched stores: {len(current_stores - catalog_stores):,}")

    # Items
    current_items = set(f_current["client_item_nbr"].unique())
    catalog_items = set(dim_item["client_item_nbr"].unique())
    item_match = len(current_items & catalog_items)
    item_pct = (item_match / len(current_items) * 100) if len(current_items) > 0 else 0
    print(f"    Items: {item_pct:.1f}% ({item_match:,}/{len(current_items):,})")
    if len(current_items - catalog_items) > 0:
        print(f"    ⚠️  Unmatched items: {len(current_items - catalog_items):,}")

    # YoY coverage (best-effort)
    if yoy_week_id_ly:
        f_ly_yoy = f_ly_all[f_ly_all["week_id"] == str(yoy_week_id_ly)]
        yoy_combos = len(f_ly_yoy.drop_duplicates(subset=["store_id", "client_item_nbr"]))
        current_combos = len(f_current.drop_duplicates(subset=["store_id", "client_item_nbr"]))
        yoy_pct = (yoy_combos / current_combos * 100) if current_combos > 0 else 0
        print("\n  YoY Comparator Coverage:")
        print(f"    yoy_week_id_ly: {yoy_week_id_ly}")
        print(f"    Coverage: {yoy_pct:.1f}% ({yoy_combos:,}/{current_combos:,} store-items)")
    else:
        print("\n  YoY Comparator Coverage:")
        print("    ⚠️  yoy_week_id_ly not set (cannot assess YoY mapping)")

    # ACTIVE FILTER IMPACT (CRITICAL)
    print("\n  Active Filter Impact:")
    active_set = set(f_active[["store_id", "client_item_nbr"]].apply(tuple, axis=1))
    current_set = set(f_current[["store_id", "client_item_nbr"]].apply(tuple, axis=1))
    overlap = len(active_set & current_set)
    inactive_count = len(current_set - active_set)
    active_pct = (overlap / len(current_set) * 100) if len(current_set) > 0 else 0

    print(f"    Active coverage: {active_pct:.1f}% of current snapshot")
    print(f"    Combinations to keep: {overlap:,}")
    if inactive_count > 0:
        print(f"    ⚠️  Inactive combinations to be removed: {inactive_count:,}")
    else:
        print("    ✓ All current combinations are active")

