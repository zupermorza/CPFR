        "demand": "seasonal_sellout_units",
    }
    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})

    required = ["store_id", "subcategory", "seasonal_sellout_units"]
    missing = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"F_STORE_SUBCATEGORY_SEASON missing required columns: {missing}")

    df = clip_nonneg(df, ["seasonal_sellout_units"])
