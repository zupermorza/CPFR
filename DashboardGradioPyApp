def compute_instock_by_levels(df_current: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Compute in-stock KPIs separately for each hierarchy level"""
    results = {}
    
    if df_current.empty:
        return results
    
    tmp = df_current.copy()
    tmp["in_stock_flag"] = (tmp["on_hand"] > 0).astype(np.int8)
    
    # Compute for each hierarchy level independently
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in tmp.columns:
            g = tmp.groupby(level_col, dropna=False, as_index=False, observed=True)
            out = g.agg(
                sites=("in_stock_flag", "count"),
                in_stock_sites=("in_stock_flag", "sum"),
                on_hand=("on_hand", "sum"),
                sales_last4=("sales_last4", "sum"),
            )
            
            out["instock_pct_sites"] = np.where(out["sites"]>0, out["in_stock_sites"]/out["sites"], np.nan)
            out["instock_pct_sales_weighted"] = out["instock_pct_sites"]
            
            out = format_percentages(out)
            out = round_numeric(out)
            results[level_col] = out
    
    return results

def compute_slow_movers_by_levels(df_current: pd.DataFrame, df_wk5: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Compute slow movers separately for each hierarchy level"""
    results = {}
    
    if df_current.empty or df_wk5.empty:
        return results
    
    base = safe_merge(df_current, df_wk5, on=["store_id","client_item_nbr"], how="left")
    slow = base[(base["on_hand_wk_-5"].fillna(0) > 0) & (base["sales_last4"].fillna(0) == 0)].copy()
    
    if slow.empty:
        return results
    
    # Aggregate by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in slow.columns:
            slow_agg = slow.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'sales_last4': 'sum',
                'on_hand_wk_-5': 'sum'
            })
            slow_agg["slow_mover_units"] = slow_agg["on_hand"]
            slow_agg = round_numeric(slow_agg)
            results[level_col] = slow_agg
    
    return results

def compute_compliance_by_levels(df_current: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Compute min/safety compliance separately for each hierarchy level"""
    results = {}
    
    if df_current.empty:
        return results
    
    df = df_current.copy()
    df["mean_wk"] = df["sales_last4"].fillna(0) / 4.0
    df["std_wk"] = np.sqrt(df["mean_wk"].clip(lower=0))
    df["suggested_safety"] = (df["std_wk"] * 1.65 + df["mean_wk"] * 1.0).clip(lower=0)
    
    if "safety_stock" not in df.columns:
        df["safety_stock"] = df["suggested_safety"]
    if "min_stock" not in df.columns:
        df["min_stock"] = df["mean_wk"]
    
    df["below_min_flag"] = (df["on_hand"] < df["min_stock"]).astype(np.int8)
    df["below_safety_flag"] = (df["on_hand"] < df["safety_stock"]).astype(np.int8)
    
    # Aggregate by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in df.columns:
            comp_agg = df.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'min_stock': 'sum',
                'safety_stock': 'sum',
                'below_min_flag': 'sum',
                'below_safety_flag': 'sum',
                'suggested_safety': 'sum'
            })
            comp_agg = round_numeric(comp_agg)
            results[level_col] = comp_agg
    
    return results

def compute_forecast(df_current_enriched: pd.DataFrame, df_next4: pd.DataFrame,
                     df_store_subcat: pd.DataFrame) -> pd.DataFrame:
    """Compute forecast (store-item level for uplift calculation)"""
    base = safe_merge(df_current_enriched, df_next4, on=["store_id","client_item_nbr"], how="left")
    wk_lvl = base["sales_last4"].fillna(0) / 4.0
    baseline_4w = base["n4w"].fillna(np.nan)
    blended_4w = np.where(pd.isna(baseline_4w), wk_lvl * 4.0, 0.6 * baseline_4w + 0.4 * (wk_lvl * 4.0))
    base["fc_final"] = pd.Series(blended_4w).clip(lower=0)

    # Apply uplift
    if not df_store_subcat.empty and ("subcategory" in base.columns):
        sub = df_store_subcat.copy()
        sub_chain = sub.groupby("subcategory", dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_chain")
        sub_store = sub.groupby(["store_id","subcategory"], dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_store")
        sub_share = safe_merge(sub_store, sub_chain, on=["subcategory"], how="left")
        sub_share["store_sub_share"] = np.where(sub_share["sub_units_chain"]>0, sub_share["sub_units_store"]/sub_share["sub_units_chain"], np.nan)
        sub_share["sum_share_subcat"] = sub_share.groupby("subcategory", observed=True)["store_sub_share"].transform("sum")
        sub_share["store_sub_share_norm"] = np.where(sub_share["sum_share_subcat"]>0, sub_share["store_sub_share"]/sub_share["sum_share_subcat"], sub_share["store_sub_share"])
        base = safe_merge(base, sub_share[["store_id","subcategory","store_sub_share_norm"]], on=["store_id","subcategory"], how="left")
        med = sub_share.groupby("subcategory", observed=True)["store_sub_share_norm"].median().rename("median_sub_share_norm").reset_index()
        base = safe_merge(base, med, on=["subcategory"], how="left")
        base["uplift_factor"] = np.where(base["median_sub_share_norm"]>0, base["store_sub_share_norm"]/base["median_sub_share_norm"], 1.0)
        if "store_trait" in base.columns:
            base["uplift_factor"] = np.where((base["store_trait"].isin(list(SMALL_TRAITS))) | (base["store_sub_share_norm"].isna()), 1.0, base["uplift_factor"])
        else:
            base["uplift_factor"] = np.where((base["store_sub_share_norm"].isna()), 1.0, base["uplift_factor"])
        base["fc_final"] = (base["fc_final"] * base["uplift_factor"]).fillna(base["fc_final"])

    return base

def compute_forecast_by_levels(df_fc: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Aggregate forecast by each hierarchy level"""
    results = {}
    
    if df_fc.empty:
        return results
    
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in df_fc.columns:
            fc_agg = df_fc.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'sales_last4': 'sum',
                'fc_final': 'sum'
            })
            fc_agg = round_numeric(fc_agg)
            results[level_col] = fc_agg
    
    return results

def compute_risk_by_levels(df_fc: pd.DataFrame, lead_time_wks: int = 2, buffer_wks: float = 0.5) -> Dict[str, pd.DataFrame]:
    """Compute stockout risk separately for each hierarchy level"""
    results = {}
    
    if df_fc.empty:
        return results
    
    df = df_fc.copy()
    df["wk_demand"] = df["fc_final"] / 4.0
    demand_horizon = (lead_time_wks + buffer_wks) * df["wk_demand"]
    df["demand_horizon"] = demand_horizon
    df["risk_gap"] = df["demand_horizon"] - df["on_hand"]
    df["stockout_risk_flag"] = (df["risk_gap"] > 0).astype(np.int8)
    df["risk_score"] = np.where(df["demand_horizon"]>0, df["risk_gap"]/df["demand_horizon"], 0)
    
    # Aggregate by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in df.columns:
            risk_agg = df.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'fc_final': 'sum',
                'wk_demand': 'sum',
                'demand_horizon': 'sum',
                'risk_gap': 'sum',
                'stockout_risk_flag': 'sum',
                'risk_score': 'mean'
            })
            risk_agg = round_numeric(risk_agg)
            results[level_col] = risk_agg
    
    return results

def compute_distribution_by_levels(df_current: pd.DataFrame,
                               df_store_subcat: pd.DataFrame,
                               item_lookup: pd.DataFrame,
                               store_lookup: pd.DataFrame,
                               hhi_threshold: float = 0.25,
                               share_excess_pp: float = 20.0) -> Tuple[Dict[str, pd.DataFrame], Dict[str, pd.DataFrame]]:
    """Compute distribution metrics separately for each hierarchy level"""
    hhi_results = {}
    over_results = {}
    
    if df_current.empty:
        return hhi_results, over_results
    
    cur = safe_merge(df_current, item_lookup, on=["client_item_nbr"], how="left")
    cur = safe_merge(cur, store_lookup, on=["store_id"], how="left")
    
    # Calculate HHI at item level first
    item_tot = cur.groupby("client_item_nbr", dropna=False, observed=True)["on_hand"].sum().reset_index(name="item_onhand_total")
    cur = safe_merge(cur, item_tot, on=["client_item_nbr"], how="left")
    cur["share_store_of_item"] = np.where(cur["item_onhand_total"]>0, cur["on_hand"]/cur["item_onhand_total"], 0)
    
    # HHI by item
    hhi = cur.groupby("client_item_nbr", dropna=False, observed=True)["share_store_of_item"].apply(lambda s: np.sum(np.square(s))).reset_index(name="hhi")
    hhi_flags = safe_merge(hhi, item_lookup[["client_item_nbr","item_id","brand","subcategory","year","level_0"]].drop_duplicates("client_item_nbr", keep="first"), on=["client_item_nbr"], how="left")
    hhi_flags["hhi_flag"] = (hhi_flags["hhi"] >= hhi_threshold).astype(np.int8)
    
    # Aggregate HHI by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in hhi_flags.columns:
            hhi_agg = hhi_flags.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'hhi': 'mean',
                'hhi_flag': 'sum'
            })
            hhi_agg = round_numeric(hhi_agg)
            hhi_results[level_col] = hhi_agg
    
    # Over-concentration
    if not df_store_subcat.empty and ("subcategory" in item_lookup.columns):
        sub = df_store_subcat.copy()
        sub_chain = sub.groupby("subcategory", dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_chain")
        sub_store = sub.groupby(["store_id","subcategory"], dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_store")
        sub_share = safe_merge(sub_store, sub_chain, on=["subcategory"], how="left")
        sub_share["store_sub_share"] = np.where(sub_share["sub_units_chain"]>0, sub_share["sub_units_store"]/sub_share["sub_units_chain"], 0)
        sub_share["sum_share_subcat"] = sub_share.groupby("subcategory", observed=True)["store_sub_share"].transform("sum")
        sub_share["store_sub_share_norm"] = np.where(sub_share["sum_share_subcat"]>0, sub_share["store_sub_share"]/sub_share["sum_share_subcat"], sub_share["store_sub_share"])

        cur2 = safe_merge(cur, sub_share[["store_id","subcategory","store_sub_share_norm"]], on=["store_id","subcategory"], how="left")
        cur2["share_gap_pp"] = 100.0 * (cur2["share_store_of_item"] - cur2["store_sub_share_norm"])
        cur2["over_concentrated_flag"] = (cur2["share_gap_pp"] >= share_excess_pp).astype(np.int8)
        
        # Aggregate by each level
        for level_col, level_name in HIERARCHY_LEVELS.items():
            if level_col in cur2.columns:
                over_agg = cur2[cur2["over_concentrated_flag"]==1].groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                    'on_hand': 'sum',
                    'share_gap_pp': 'mean'
                })
                over_agg = round_numeric(over_agg)
                over_results[level_col] = over_agg

    return hhi_results, over_results

