def build_gold_fact_base(
    f_current: pd.DataFrame,
    f_ly_yoy: pd.DataFrame,
    dim_item: pd.DataFrame,
    dim_store: pd.DataFrame,
) -> pd.DataFrame:
    """
    Build gold fact BASE (before ACTIVE filter and before multi-week history merge)
    Grain: store_id × client_item_nbr × week_id
    """
    print("\n[BUILDING GOLD FACT BASE: F_STORE_ITEM_WEEK]")

    fact = f_current.copy()
    print(f"  Base (current): {len(fact):,} rows")

    # Join YoY comparator (already aligned to current week_id)
    if f_ly_yoy is not None and not f_ly_yoy.empty:
        fact = safe_merge(fact, f_ly_yoy, on=["store_id", "client_item_nbr", "week_id"], how="left")
        if "sellout_units_ly_yoy" in fact.columns:
            fact["sellout_units_ly_yoy"] = fact["sellout_units_ly_yoy"].fillna(0)
        else:
            fact["sellout_units_ly_yoy"] = 0
        print(f"  After YoY join: {len(fact):,} rows")
    else:
        fact["sellout_units_ly_yoy"] = 0
        print("  ⚠️  YoY comparator not available; sellout_units_ly_yoy set to 0")

    # Join DIM_ITEM
    fact = safe_merge(fact, dim_item, on=["client_item_nbr"], how="left")
    print(f"  After DIM_ITEM join: {len(fact):,} rows")

    # Join DIM_STORE
    fact = safe_merge(fact, dim_store, on=["store_id"], how="left")
    print(f"  After DIM_STORE join: {len(fact):,} rows")

    # Smart dedup: preserve dims, sum measures
    initial_rows = len(fact)

    dimension_cols = [
        "week_id", "as_of_date", "week_id_ly_yoy",  # TIME
        "store_id", "client_item_nbr",              # KEYS
        # STORE DIMS
        "store_name", "state", "region", "store_tier", "store_format", "cluster",
        # ITEM DIMS
        "item_desc", "subcategory", "category", "brand", "item_status",
    ]
    measure_cols = ["sellout_units_lw", "on_hand_units", "on_order_units", "sellout_units_ly_yoy"]

    dim_keep = [c for c in dimension_cols if c in fact.columns]
    meas_sum = [c for c in measure_cols if c in fact.columns]

    group_keys = ["store_id", "client_item_nbr"]
    if "week_id" in fact.columns:
        group_keys.append("week_id")

    agg_dict = {c: "first" for c in dim_keep if c not in group_keys}
    agg_dict.update({c: "sum" for c in meas_sum})

    fact = fact.groupby(group_keys, dropna=False, as_index=False).agg(agg_dict)

    if len(fact) < initial_rows:
        print(f"  ⚠️  Dedup removed {initial_rows - len(fact):,} rows")

    print(f"✓ Gold fact BASE built: {len(fact):,} rows (before active filter)")
    return fact

def apply_active_filter(fact: pd.DataFrame, f_active: pd.DataFrame) -> pd.DataFrame:
    """MANDATORY: keep only active store-item combinations (semi-join via inner merge)."""
    print("\n[APPLYING MANDATORY ACTIVE FILTER]")

    initial_rows = len(fact)
    fact = fact.merge(f_active, on=["store_id", "client_item_nbr"], how="inner")

    removed_rows = initial_rows - len(fact)
    removed_pct = (removed_rows / initial_rows * 100) if initial_rows > 0 else 0

    print(f"  Before filter: {initial_rows:,} rows")
    print(f"  After filter:  {len(fact):,} rows")
    if removed_rows > 0:
        print(f"  ⚠️  REMOVED {removed_rows:,} INACTIVE combinations ({removed_pct:.1f}%)")
    else:
        print("  ✓ All combinations were already active")

    return fact

