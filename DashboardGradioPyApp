def compute_inventory_kpis_by_levels(df_fc: pd.DataFrame, hierarchy_levels: Dict[str, str], efficiency_base: float = 100.0) -> Dict[str, pd.DataFrame]:
    """
    Compute inventory KPIs at each hierarchy level:
    - avg_wk_fc: Average weekly forecast (fc_final / 4)
    - avg_wk_l4w: Average weekly last 4 weeks (sales_last4 / 4)
    - doi_days: Days on inventory vs forecast (on_hand / (fc_final / 28))
    - eff_per_base: Efficiency per base units ((sales_last4 / on_hand) * efficiency_base)
    - coverage_wks_fc: Weeks of coverage vs forecast (on_hand / (fc_final / 4))
    """
    kpi_results = {}
    
    if df_fc.empty:
        return kpi_results
    
    print(f"  Computing inventory KPIs with efficiency_base={efficiency_base}")
    
    for level_col, level_name in hierarchy_levels.items():
        if level_col not in df_fc.columns:
            continue
        
        # Aggregate by level
        agg = df_fc.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
            'on_hand': 'sum',
            'sales_last4': 'sum',
            'fc_final': 'sum'
        })
        
        # Calculate KPIs
        agg['avg_wk_fc'] = agg['fc_final'] / 4.0
        agg['avg_wk_l4w'] = agg['sales_last4'] / 4.0
        
        # DOI days: on_hand / daily_fc where daily_fc = fc_final / 28
        daily_fc = agg['fc_final'] / 28.0
        agg['doi_days'] = np.where(daily_fc > 0, agg['on_hand'] / daily_fc, np.nan)
        
        # Efficiency per base: (sales_last4 / on_hand) * efficiency_base
        agg['eff_per_base'] = np.where(agg['on_hand'] > 0, (agg['sales_last4'] / agg['on_hand']) * efficiency_base, np.nan)
        
        # Coverage weeks: on_hand / weekly_fc where weekly_fc = fc_final / 4
        weekly_fc = agg['fc_final'] / 4.0
        agg['coverage_wks_fc'] = np.where(weekly_fc > 0, agg['on_hand'] / weekly_fc, np.nan)
        
        # Round to 2 decimals
        numeric_cols = ['avg_wk_fc', 'avg_wk_l4w', 'doi_days', 'eff_per_base', 'coverage_wks_fc']
        for col in numeric_cols:
            if col in agg.columns:
                agg[col] = agg[col].round(2)
        
        kpi_results[level_col] = agg
    
    return kpi_results

def enrich_instock_tables_with_kpis(outputs: Dict[str, pd.DataFrame], kpi_by_levels: Dict[str, pd.DataFrame]) -> Dict[str, pd.DataFrame]:
    """
    Enrich in-stock tables with inventory KPI metrics by merging on hierarchy keys.
    """
    print("  Enriching in-stock tables with inventory KPIs...")
    
    for level_col, kpi_df in kpi_by_levels.items():
        instock_key = f"instock_{level_col}"
        
        if instock_key in outputs and not outputs[instock_key].empty:
            # Merge KPIs into existing instock table
            try:
                # Get KPI columns only (exclude aggregated columns already in instock)
                kpi_cols = [level_col, 'doi_days', 'eff_per_base']
                available_kpi_cols = [c for c in kpi_cols if c in kpi_df.columns]
                
                if len(available_kpi_cols) > 1:  # More than just the key column
                    outputs[instock_key] = pd.merge(
                        outputs[instock_key],
                        kpi_df[available_kpi_cols],
                        on=level_col,
                        how='left'
                    )
                    print(f"    ✓ Enriched {instock_key} with {len(available_kpi_cols)-1} KPIs")
            except Exception as e:
                print(f"    ⚠ Warning: Could not enrich {instock_key}: {e}")
        else:
            # If instock table doesn't exist, use KPI table as fallback
            outputs[instock_key] = kpi_df
            print(f"    ✓ Created {instock_key} from KPI data")
    
    return outputs

def compute_instock_by_levels(df_current: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Compute in-stock KPIs separately for each hierarchy level"""
    results = {}
    
    if df_current.empty:
        return results
    
    tmp = df_current.copy()
    tmp["in_stock_flag"] = (tmp["on_hand"] > 0).astype(np.int8)
    tmp["avg_wk_sales"] = tmp["sales_last4"].fillna(0) / 4.0
    tmp["weeks_of_supply"] = np.where(tmp["avg_wk_sales"] > 0, tmp["on_hand"] / tmp["avg_wk_sales"], np.nan)
    tmp["overstock_flag"] = ((tmp["on_hand"] > 1) & (tmp["weeks_of_supply"] > 8)).astype(np.int8)
    
    # Compute for each hierarchy level independently
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in tmp.columns:
            g = tmp.groupby(level_col, dropna=False, as_index=False, observed=True)
            out = g.agg(
                sites=("in_stock_flag", "count"),
                in_stock_sites=("in_stock_flag", "sum"),
                on_hand=("on_hand", "sum"),
                sales_last4=("sales_last4", "sum"),
                overstock_combinations=("overstock_flag", "sum"),
            )
            
            out["instock_pct_sites"] = np.where(out["sites"]>0, out["in_stock_sites"]/out["sites"], np.nan)
            out["overstock_pct_combinations"] = np.where(out["sites"]>0, out["overstock_combinations"]/out["sites"], np.nan)

            if level_col == "store_trait":
                total_row = pd.DataFrame([{
                    "store_trait": "TOTAL",
                    "sites": out["sites"].sum(),
                    "in_stock_sites": out["in_stock_sites"].sum(),
                    "on_hand": out["on_hand"].sum(),
                    "sales_last4": out["sales_last4"].sum(),
                    "overstock_combinations": out["overstock_combinations"].sum()
                }])
                total_row["instock_pct_sites"] = np.where(
                    total_row["sites"] > 0,
                    total_row["in_stock_sites"] / total_row["sites"],
                    np.nan
                )
                total_row["overstock_pct_combinations"] = np.where(
                    total_row["sites"] > 0,
                    total_row["overstock_combinations"] / total_row["sites"],
                    np.nan
                )
                out = pd.concat([total_row, out], ignore_index=True)
            
            out = format_percentages(out)
            out = round_numeric(out)
            results[level_col] = out
    
    return results

def compute_overstock_detail(df_current: pd.DataFrame) -> pd.DataFrame:
    if df_current.empty:
        return pd.DataFrame()
    df = df_current.copy()
    df["avg_wk_sales"] = df["sales_last4"].fillna(0) / 4.0
    df["weeks_of_supply"] = np.where(df["avg_wk_sales"] > 0, df["on_hand"] / df["avg_wk_sales"], np.nan)
    df["overstock_flag"] = ((df["on_hand"] > 10) & (df["weeks_of_supply"] > 10)).astype(np.int8)
    total_combinations = len(df)
    overstock_pct = (100.0 * df["overstock_flag"].sum() / total_combinations) if total_combinations > 0 else 0.0
    detail = df[df["overstock_flag"] == 1].copy()
    detail["overstock_pct_total_combinations"] = overstock_pct
    keep_cols = [c for c in ["store_id", "client_item_nbr", "item_id", "brand", "store_trait", "state", "on_hand", "sales_last4", "weeks_of_supply"] if c in detail.columns]
    keep_cols.append("overstock_pct_total_combinations")
    return round_numeric(detail[keep_cols]) if keep_cols else pd.DataFrame()

def compute_inventory_split(df_current: pd.DataFrame) -> pd.DataFrame:
    if df_current.empty:
        return pd.DataFrame(columns=["inventory_bucket", "num_combinations"])
    on_hand = df_current["on_hand"].fillna(0)
    buckets = pd.Series(np.select(
        [on_hand < 3, (on_hand >= 3) & (on_hand <= 8), on_hand > 8.0],
        ["<3 units", "3-8 units", ">8 units"],
        default="unknown"
    ))
    split = buckets.value_counts(dropna=False).rename_axis("inventory_bucket").reset_index(name="num_combinations")
    order = {"<3 units": 0, "3-8 units": 1, ">8 units": 2, "unknown": 3}
    split["sort_order"] = split["inventory_bucket"].map(order).fillna(99)
    split = split.sort_values("sort_order").drop(columns=["sort_order"]).reset_index(drop=True)
    return split

def compute_slow_movers_by_levels(df_current: pd.DataFrame, df_wk5: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Compute slow movers separately for each hierarchy level"""
    results = {}
    
    if df_current.empty or df_wk5.empty:
        return results
    
    base = safe_merge(df_current, df_wk5, on=["store_id","client_item_nbr"], how="left")
    slow = base[(base["on_hand_wk_-5"].fillna(0) > 0) & (base["sales_last4"].fillna(0) == 0)].copy()
    
    if slow.empty:
        return results
    
    # Aggregate by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in slow.columns:
            slow_agg = slow.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'sales_last4': 'sum',
                'on_hand_wk_-5': 'sum'
            })
            slow_agg["slow_mover_units"] = slow_agg["on_hand"]
            slow_agg = round_numeric(slow_agg)
            results[level_col] = slow_agg
    
    return results

def compute_compliance_by_levels(df_current: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Compute min/safety compliance separately for each hierarchy level"""
    results = {}
    
    if df_current.empty:
        return results
    
    df = df_current.copy()
    df["mean_wk"] = df["sales_last4"].fillna(0) / 4.0
    df["std_wk"] = np.sqrt(df["mean_wk"].clip(lower=0))
    df["suggested_safety"] = (df["std_wk"] * 1.65 + df["mean_wk"] * 1.0).clip(lower=0)
    
    if "safety_stock" not in df.columns:
        df["safety_stock"] = df["suggested_safety"]
    if "min_stock" not in df.columns:
        df["min_stock"] = df["mean_wk"]
    
    df["below_min_flag"] = (df["on_hand"] < df["min_stock"]).astype(np.int8)
    df["below_safety_flag"] = (df["on_hand"] < df["safety_stock"]).astype(np.int8)
    
    # Aggregate by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in df.columns:
            comp_agg = df.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'min_stock': 'sum',
                'safety_stock': 'sum',
                'below_min_flag': 'sum',
                'below_safety_flag': 'sum',
                'suggested_safety': 'sum'
            })
            comp_agg = round_numeric(comp_agg)
            results[level_col] = comp_agg
    
    return results

def compute_forecast(df_current_enriched: pd.DataFrame, df_next4: pd.DataFrame,
                     df_store_subcat: pd.DataFrame,
                     uplift_enabled: bool = True,
                     uplift_cap_min: float = 0.70,
                     uplift_cap_max: float = 1.50,
                     uplift_method: str = "cap_ratio_to_median",
                     uplift_benchmark: str = "trait_median") -> pd.DataFrame:
    """Compute forecast (store-item level for uplift calculation)"""
    base = safe_merge(df_current_enriched, df_next4, on=["store_id","client_item_nbr"], how="left")
    wk_lvl = base["sales_last4"].fillna(0) / 4.0
    baseline_4w = base["n4w"].fillna(np.nan)
    blended_4w = np.where(pd.isna(baseline_4w), wk_lvl * 4.0, 0.6 * baseline_4w + 0.4 * (wk_lvl * 4.0))
    base["fc_final"] = pd.Series(blended_4w).clip(lower=0)

    # Apply uplift with guardrails at store-subcategory level
    if not df_store_subcat.empty and ("subcategory" in base.columns):
        sub = df_store_subcat.copy()
        sub_chain = sub.groupby("subcategory", dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_chain")
        sub_store = sub.groupby(["store_id","subcategory"], dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_store")
        sub_share = safe_merge(sub_store, sub_chain, on=["subcategory"], how="left")
        sub_share["store_sub_share"] = np.where(sub_share["sub_units_chain"]>0, sub_share["sub_units_store"]/sub_share["sub_units_chain"], np.nan)
        sub_share["sum_share_subcat"] = sub_share.groupby("subcategory", observed=True)["store_sub_share"].transform("sum")
        sub_share["store_sub_share_norm"] = np.where(sub_share["sum_share_subcat"]>0, sub_share["store_sub_share"]/sub_share["sum_share_subcat"], sub_share["store_sub_share"])
        base = safe_merge(base, sub_share[["store_id","subcategory","store_sub_share_norm"]], on=["store_id","subcategory"], how="left")
        med_global = sub_share.groupby("subcategory", observed=True)["store_sub_share_norm"].median().rename("median_sub_share_norm").reset_index()
        base = safe_merge(base, med_global, on=["subcategory"], how="left")

        if "store_trait" in base.columns:
            store_trait_map = base[["store_id","store_trait"]].drop_duplicates()
            sub_share = safe_merge(sub_share, store_trait_map, on=["store_id"], how="left")
            med_trait = sub_share.groupby(["subcategory","store_trait"], observed=True)["store_sub_share_norm"] \
                .median().rename("median_trait_sub_share_norm").reset_index()
            base = safe_merge(base, med_trait, on=["subcategory","store_trait"], how="left")
            if uplift_benchmark == "trait_median":
                base["benchmark_sub_share_norm"] = base["median_trait_sub_share_norm"].fillna(base["median_sub_share_norm"])
            else:
                base["benchmark_sub_share_norm"] = base["median_sub_share_norm"]
        else:
            base["benchmark_sub_share_norm"] = base["median_sub_share_norm"]

        uplift_df = compute_uplift_factor(
            base["store_sub_share_norm"],
            base["benchmark_sub_share_norm"],
            uplift_enabled=uplift_enabled,
            uplift_method=uplift_method,
            uplift_cap_min=uplift_cap_min,
            uplift_cap_max=uplift_cap_max
        )

        if "store_trait" in base.columns:
            small_trait_mask = base["store_trait"].isin(list(SMALL_TRAITS))
            uplift_df.loc[small_trait_mask, ["uplift_factor_raw", "uplift_factor_applied"]] = 1.0
            uplift_df.loc[small_trait_mask, "uplift_capped_flag"] = False

        base["uplift_raw_store_subcat"] = uplift_df["uplift_factor_raw"]
        base["uplift_applied_store_subcat"] = uplift_df["uplift_factor_applied"]
        base["uplift_capped_flag"] = uplift_df["uplift_capped_flag"]

        base["fc_baseline"] = base["fc_final"]
        subcat_keys = ["store_id", "subcategory"]
        base["subcat_fc_total"] = base.groupby(subcat_keys, dropna=False, observed=True)["fc_baseline"].transform("sum")
        base["subcat_fc_uplifted"] = base["subcat_fc_total"] * base["uplift_applied_store_subcat"]
        base["uplift_delta"] = base["subcat_fc_uplifted"] - base["subcat_fc_total"]

        baseline_share = np.where(base["subcat_fc_total"] > 0,
                                  base["fc_baseline"] / base["subcat_fc_total"],
                                  np.nan)
        sales_share = np.where(
            base.groupby(subcat_keys, dropna=False, observed=True)["sales_last4"].transform("sum") > 0,
            base["sales_last4"] / base.groupby(subcat_keys, dropna=False, observed=True)["sales_last4"].transform("sum"),
            np.nan
        )
        sku_count = base.groupby(subcat_keys, dropna=False, observed=True)["client_item_nbr"].transform("count")
        equal_share = np.where(sku_count > 0, 1.0 / sku_count, 0)

        share = pd.Series(baseline_share, index=base.index)
        share = share.fillna(pd.Series(sales_share, index=base.index))
        share = share.fillna(pd.Series(equal_share, index=base.index))
        share_sum = share.groupby([base["store_id"], base["subcategory"]]).transform("sum")
        share = np.where(share_sum > 0, share / share_sum, 0)

        base["fc_final_post_uplift"] = base["fc_baseline"] + (base["uplift_delta"] * share)
        base["fc_final_post_uplift"] = base["fc_final_post_uplift"].clip(lower=0)
        base["fc_final"] = base["fc_final_post_uplift"]
        base = base.drop(columns=["fc_baseline", "subcat_fc_total", "subcat_fc_uplifted", "uplift_delta"])
    else:
        base["uplift_raw_store_subcat"] = 1.0
        base["uplift_applied_store_subcat"] = 1.0
        base["uplift_capped_flag"] = False
        base["fc_final_post_uplift"] = base["fc_final"]

    return base

def compute_forecast_by_levels(df_fc: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Aggregate forecast by each hierarchy level"""
    results = {}
    
    if df_fc.empty:
        return results
    
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in df_fc.columns:
            fc_agg = df_fc.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'sales_last4': 'sum',
                'fc_final': 'sum'
            })
            fc_agg = round_numeric(fc_agg)
            results[level_col] = fc_agg
    
    return results

def compute_risk_by_levels(df_fc: pd.DataFrame, lead_time_wks: float = 2, buffer_wks: float = 0.5,
                           total_horizon_wks: Optional[float] = None) -> Dict[str, pd.DataFrame]:
    """Compute stockout risk separately for each hierarchy level"""
    results = {}
    
    if df_fc.empty:
        return results
    
    df = df_fc.copy()
    df["wk_demand"] = df["fc_final"] / 4.0
    horizon_wks = total_horizon_wks if total_horizon_wks is not None else (lead_time_wks + buffer_wks)
    demand_horizon = horizon_wks * df["wk_demand"]
    df["demand_horizon"] = demand_horizon
    df["risk_gap"] = df["demand_horizon"] - df["on_hand"]
    df["stockout_risk_flag"] = (df["risk_gap"] > 0).astype(np.int8)
    df["risk_score"] = np.where(df["demand_horizon"]>0, df["risk_gap"]/df["demand_horizon"], 0)
    
    # Aggregate by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in df.columns:
            risk_agg = df.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'on_hand': 'sum',
                'fc_final': 'sum',
                'wk_demand': 'sum',
                'demand_horizon': 'sum',
                'risk_gap': 'sum',
                'stockout_risk_flag': 'sum',
                'risk_score': 'mean'
            })
            risk_agg = round_numeric(risk_agg)
            results[level_col] = risk_agg
    
    return results

def compute_distribution_by_levels(df_current: pd.DataFrame,
                               df_store_subcat: pd.DataFrame,
                               item_lookup: pd.DataFrame,
                               store_lookup: pd.DataFrame,
                               hhi_threshold: float = 0.25,
                               share_excess_pp: float = 20.0) -> Tuple[Dict[str, pd.DataFrame], Dict[str, pd.DataFrame]]:
    """Compute distribution metrics separately for each hierarchy level"""
    hhi_results = {}
    over_results = {}
    
    if df_current.empty:
        return hhi_results, over_results
    
    # Two-step item lookup to prevent data loss
    _l1_cli, _l2_itm = _build_item_lookups_for_cpfr(item_lookup)
    
    cur = df_current.copy()
    
    # Step 1: Map client_item_nbr to item_id
    if _l1_cli is not None and not _l1_cli.empty:
        cur = safe_merge(cur, _l1_cli, on=["client_item_nbr"], how="left")
    
    # Step 2: Add item attributes
    if _l2_itm is not None and not _l2_itm.empty:
        cur = safe_merge(cur, _l2_itm, on=["item_id"], how="left")
    
    # Add store attributes
    cur = safe_merge(cur, store_lookup, on=["store_id"], how="left")
    
    # Calculate HHI at item level first
    item_tot = cur.groupby("client_item_nbr", dropna=False, observed=True)["on_hand"].sum().reset_index(name="item_onhand_total")
    cur = safe_merge(cur, item_tot, on=["client_item_nbr"], how="left")
    cur["share_store_of_item"] = np.where(cur["item_onhand_total"]>0, cur["on_hand"]/cur["item_onhand_total"], 0)
    
    # HHI by item
    hhi = cur.groupby("client_item_nbr", dropna=False, observed=True)["share_store_of_item"].apply(lambda s: np.sum(np.square(s))).reset_index(name="hhi")
    
    # Add item attributes to HHI flags
    if _l1_cli is not None and not _l1_cli.empty:
        hhi_flags = safe_merge(hhi, _l1_cli, on=["client_item_nbr"], how="left")
    else:
        hhi_flags = hhi.copy()
    
    if _l2_itm is not None and not _l2_itm.empty:
        hhi_flags = safe_merge(hhi_flags, _l2_itm, on=["item_id"], how="left")
    
    hhi_flags["hhi_flag"] = (hhi_flags["hhi"] >= hhi_threshold).astype(np.int8)
    
    # Aggregate HHI by each level
    for level_col, level_name in HIERARCHY_LEVELS.items():
        if level_col in hhi_flags.columns:
            hhi_agg = hhi_flags.groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                'hhi': 'mean',
                'hhi_flag': 'sum'
            })
            hhi_agg = round_numeric(hhi_agg)
            hhi_results[level_col] = hhi_agg
    
    # Over-concentration
    if not df_store_subcat.empty and ("subcategory" in cur.columns):
        sub = df_store_subcat.copy()
        sub_chain = sub.groupby("subcategory", dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_chain")
        sub_store = sub.groupby(["store_id","subcategory"], dropna=False, observed=True)["units"].sum().reset_index(name="sub_units_store")
        sub_share = safe_merge(sub_store, sub_chain, on=["subcategory"], how="left")
        sub_share["store_sub_share"] = np.where(sub_share["sub_units_chain"]>0, sub_share["sub_units_store"]/sub_share["sub_units_chain"], 0)
        sub_share["sum_share_subcat"] = sub_share.groupby("subcategory", observed=True)["store_sub_share"].transform("sum")
        sub_share["store_sub_share_norm"] = np.where(sub_share["sum_share_subcat"]>0, sub_share["store_sub_share"]/sub_share["sum_share_subcat"], sub_share["store_sub_share"])

        cur2 = safe_merge(cur, sub_share[["store_id","subcategory","store_sub_share_norm"]], on=["store_id","subcategory"], how="left")
        cur2["share_gap_pp"] = 100.0 * (cur2["share_store_of_item"] - cur2["store_sub_share_norm"])
        cur2["over_concentrated_flag"] = (cur2["share_gap_pp"] >= share_excess_pp).astype(np.int8)
        
        # Aggregate by each level
        for level_col, level_name in HIERARCHY_LEVELS.items():
            if level_col in cur2.columns:
                over_agg = cur2[cur2["over_concentrated_flag"]==1].groupby(level_col, dropna=False, as_index=False, observed=True).agg({
                    'on_hand': 'sum',
                    'share_gap_pp': 'mean'
                })
                over_agg = round_numeric(over_agg)
                over_results[level_col] = over_agg

    return hhi_results, over_results

