# === BEGIN: Two-step item lookup helper ===
def _build_item_lookups_for_cpfr(df_lookup):
    """
    Creates two separate lookup tables to prevent data loss:
    - l1_client: Maps client_item_nbr -> item_id (1:1 or many:1)
    - l2_item: Canonical item attributes by item_id (1:1)
    
    This prevents losing records when multiple client items map to same item_id
    """
    if df_lookup is None or len(df_lookup) == 0:
        return None, None

    df = df_lookup.copy()
    
    # Canonicalize keys
    if "client_item_nbr" in df.columns:
        df["client_item_nbr"] = df["client_item_nbr"].astype(str).str.strip()
    if "item_id" in df.columns:
        df["item_id"] = df["item_id"].astype(str).str.strip()

    # L1: Mapping table (client_item_nbr -> item_id)
    if "client_item_nbr" in df.columns and "item_id" in df.columns:
        l1_client = df[["client_item_nbr", "item_id"]].drop_duplicates(subset=["client_item_nbr"])
    else:
        l1_client = pd.DataFrame()

    # L2: Canonical attributes by item_id
    if "item_id" in df.columns:
        attribute_cols = [c for c in ["item_id", "brand", "subcategory", "year", "level_0"] if c in df.columns]
        l2_item = df[attribute_cols].drop_duplicates(subset=["item_id"], keep="first")
    else:
        l2_item = pd.DataFrame()

    return l1_client, l2_item
# === END: Two-step item lookup helper ===

def lower_cols(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = [c.strip().lower() for c in df.columns]
    return df

def optimize_dtypes(df: pd.DataFrame) -> pd.DataFrame:
    """Convert to efficient data types to reduce memory usage"""
    for col in df.columns:
        if df[col].dtype == 'object':
            if col in ['store_id', 'client_item_nbr', 'item_id', 'store_trait', 'state', 'brand', 'level_0', 'subcategory']:
                df[col] = df[col].astype('category')
        elif df[col].dtype == 'float64':
            df[col] = pd.to_numeric(df[col], downcast='float')
        elif df[col].dtype == 'int64':
            df[col] = pd.to_numeric(df[col], downcast='integer')
    return df

def normalize_keys(df: pd.DataFrame) -> pd.DataFrame:
    for key in ["store_id","item_id","client_item_nbr"]:
        if key in df.columns:
            df[key] = df[key].astype(str).str.strip()
    if "store_id" in df.columns:
        df["store_id"] = df["store_id"].str.replace(r"\.0$", "", regex=True)
    if "store_trait" in df.columns:
        st = pd.to_numeric(df["store_trait"], errors="coerce")
        mapped = st.map(TRAIT_MAP)
        df["store_trait"] = mapped.fillna(df["store_trait"].astype(str).str.strip())
    return df

def clip_nonneg(df: pd.DataFrame, cols: List[str]) -> pd.DataFrame:
    for c in cols:
        if c in df.columns:
            df[c] = pd.to_numeric(df[c], errors="coerce").fillna(0).clip(lower=0)
    return df

def dedup_sum(df: pd.DataFrame, keys: List[str], sum_cols: List[str], max_cols: List[str] = None) -> pd.DataFrame:
    agg_dict = {c: "sum" for c in sum_cols if c in df.columns}
    if max_cols:
        for c in max_cols:
            if c in df.columns:
                agg_dict[c] = "max"
    return df.groupby(keys, dropna=False, as_index=False, observed=True).agg(agg_dict)

def aggregate_duplicates(df: pd.DataFrame, keys: List[str], policy: str = "sum",
                         numeric_cols: Optional[List[str]] = None) -> Tuple[pd.DataFrame, Dict]:
    if df.empty:
        diagnostics = {
            "dup_rate": 0.0,
            "duplicated_keys": 0,
            "total_rows": 0,
            "top_keys": pd.DataFrame(columns=keys + ["row_count"])
        }
        return df.copy(), diagnostics

    key_counts = df.groupby(keys, dropna=False, observed=True).size().rename("row_count")
    duplicated_keys = int((key_counts > 1).sum())
    total_rows = len(df)
    dup_rate = duplicated_keys / total_rows if total_rows else 0.0
    top_keys = key_counts.sort_values(ascending=False).head(10).reset_index()

    if numeric_cols is None:
        numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    numeric_cols = [c for c in numeric_cols if c in df.columns]

    if policy == "max":
        agg_dict = {c: "max" for c in numeric_cols}
        aggregated = df.groupby(keys, dropna=False, as_index=False, observed=True).agg(agg_dict)
    elif policy == "first":
        aggregated = df.sort_index().drop_duplicates(subset=keys, keep="first")
    else:
        agg_dict = {c: "sum" for c in numeric_cols}
        aggregated = df.groupby(keys, dropna=False, as_index=False, observed=True).agg(agg_dict)

    diagnostics = {
        "dup_rate": dup_rate,
        "duplicated_keys": duplicated_keys,
        "total_rows": total_rows,
        "top_keys": top_keys
    }
    return aggregated, diagnostics

def safe_merge(left: pd.DataFrame, right: pd.DataFrame, on: List[str], how: str = "left") -> pd.DataFrame:
    right_dedup = right.drop_duplicates(on)
    return pd.merge(left, right_dedup, on=on, how=how)

def compute_uplift_factor(store_sub_share_norm: pd.Series, benchmark_share_norm: pd.Series,
                          uplift_enabled: bool = True,
                          uplift_method: str = "cap_ratio_to_median",
                          uplift_cap_min: float = 0.70,
                          uplift_cap_max: float = 1.50) -> pd.DataFrame:
    valid = (store_sub_share_norm.notna() & benchmark_share_norm.notna() &
             (store_sub_share_norm > 0) & (benchmark_share_norm > 0))
    uplift_factor_raw = pd.Series(np.where(valid, store_sub_share_norm / benchmark_share_norm, 1.0),
                                  index=store_sub_share_norm.index)

    if not uplift_enabled or uplift_method == "none":
        uplift_factor_applied = pd.Series(1.0, index=store_sub_share_norm.index)
    elif uplift_method == "log_shrink":
        log_raw = np.log(uplift_factor_raw.clip(lower=1e-6))
        log_min = np.log(uplift_cap_min)
        log_max = np.log(uplift_cap_max)
        uplift_factor_applied = np.exp(log_raw.clip(lower=log_min, upper=log_max))
    else:
        uplift_factor_applied = uplift_factor_raw.clip(lower=uplift_cap_min, upper=uplift_cap_max)

    uplift_factor_applied = np.where(valid, uplift_factor_applied, 1.0)
    uplift_capped_flag = valid & ((uplift_factor_raw < uplift_cap_min) | (uplift_factor_raw > uplift_cap_max))

    return pd.DataFrame({
        "uplift_factor_raw": uplift_factor_raw,
        "uplift_factor_applied": uplift_factor_applied,
        "uplift_capped_flag": uplift_capped_flag
    })

def compute_inventory_aggregation(df: pd.DataFrame) -> Tuple[pd.DataFrame, Dict]:
    if "store_id" not in df.columns or "item_id" not in df.columns:
        diag = {
            "dup_rate": 0.0,
            "num_aggregated_rows": 0,
            "top_offenders": pd.DataFrame(columns=["store_id", "item_id", "dup_count", "on_hand_agg"])
        }
        df = df.copy()
        df["on_hand_agg"] = df["on_hand"] if "on_hand" in df.columns else 0
        df["inventory_aggregated_flag"] = False
        return df, diag

    key_counts = df.groupby(["store_id", "item_id"], dropna=False, observed=True).size().rename("dup_count")
    total_unique = len(key_counts)
    duplicated_keys = int((key_counts > 1).sum())
    dup_rate = duplicated_keys / total_unique if total_unique else 0.0

    agg_on_hand = df.groupby(["store_id", "item_id"], dropna=False, observed=True)["on_hand"].sum().rename("on_hand_agg")
    agg = pd.concat([key_counts, agg_on_hand], axis=1).reset_index()
    top_offenders = agg.sort_values("dup_count", ascending=False).head(50)

    df = safe_merge(df, agg[["store_id", "item_id", "on_hand_agg", "dup_count"]],
                    on=["store_id", "item_id"], how="left")
    df["inventory_aggregated_flag"] = df["dup_count"].fillna(0) > 1
    df = df.drop(columns=["dup_count"])

    diag = {
        "dup_rate": dup_rate,
        "num_aggregated_rows": int(df["inventory_aggregated_flag"].sum()),
        "top_offenders": top_offenders
    }
    return df, diag

def compute_statistical_need_cap(history_per_week: pd.Series,
                                 total_horizon_wks: float,
                                 z_value: float = 3.0,
                                 abs_cap: int = 1000) -> float:
    history_clean = history_per_week.dropna()
    if history_clean.empty:
        return float(abs_cap)
    if len(history_clean) < 2:
        median_val = float(history_clean.median())
        cap_per_week = median_val * 2
    else:
        median_val = float(history_clean.median())
        iqr_val = float(history_clean.quantile(0.75) - history_clean.quantile(0.25))
        cap_per_week = median_val + z_value * iqr_val

    cap_units = np.ceil(cap_per_week * total_horizon_wks)
    return float(min(abs_cap, cap_units))

def compute_additional_needed_units(demand_horizon_units: pd.Series,
                                    inventory_position: pd.Series,
                                    history_totals: pd.DataFrame,
                                    history_block_weeks: int,
                                    total_horizon_wks: float,
                                    z_value: float = 3.0,
                                    abs_cap: int = 1000) -> pd.DataFrame:
    raw_need = np.ceil(np.maximum(0, demand_horizon_units - inventory_position))
    if history_totals.empty:
        cap_units = pd.Series(abs_cap, index=demand_horizon_units.index)
    else:
        per_week_hist = history_totals.div(history_block_weeks)
        cap_units = per_week_hist.apply(
            lambda row: compute_statistical_need_cap(row, total_horizon_wks, z_value=z_value, abs_cap=abs_cap),
            axis=1
        )
    capped_need = np.minimum(raw_need, cap_units)
    need_capped_flag = raw_need > cap_units

    return pd.DataFrame({
        "additional_needed_raw": raw_need.astype("Int64"),
        "additional_needed_units": capped_need.astype("Int64"),
        "need_cap_units": cap_units,
        "need_capped_flag": need_capped_flag
    })

def format_percentages(df: pd.DataFrame) -> pd.DataFrame:
    """Convert decimal percentages to percentage format with 1 decimal"""
    percent_cols = [col for col in df.columns if any(x in col.lower() for x in ['pct', 'percent', 'rate', 'ratio', 'instock'])]
    for col in percent_cols:
        if col in df.columns and pd.api.types.is_numeric_dtype(df[col]):
            df[col] = (df[col] * 100).round(1)
    return df

def round_numeric(df: pd.DataFrame) -> pd.DataFrame:
    """Round all numeric columns to 1 decimal place"""
    numeric_cols = df.select_dtypes(include=[np.number]).columns
    for col in numeric_cols:
        df[col] = df[col].round(1)
    return df

def apply_hierarchy_filters(df: pd.DataFrame, filters: Dict) -> pd.DataFrame:
    """Apply hierarchy filters to dataframe"""
    if df.empty:
        return df
    
    for filter_col, filter_values in filters.items():
        if filter_col in df.columns and filter_values:
            df = df[df[filter_col].isin(filter_values)]
    
    return df

