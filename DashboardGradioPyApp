def _compute_severity(df: pd.DataFrame, flag_name: str, kpi_rules: dict) -> pd.Series:
    """Severity score used to rank store-item actions (higher = more severe)."""
    min_safety_days = float(kpi_rules.get("min_safety_stock_days", 7))
    overstock_days = float(kpi_rules.get("overstock_threshold_days", 60))
    threshold_weeks = int(kpi_rules.get("new_item_history_threshold_weeks", 4))
    threshold_units = float(kpi_rules.get("low_history_threshold_units", 10))

    coverage = df.get("coverage_days", pd.Series(np.nan, index=df.index)).fillna(0)

    if flag_name == "oos_risk_flag":
        inv0_and_selling = (df.get("on_hand_units", 0) == 0) & (df.get("sellout_units_lw", 0) > 0)
        return np.where(inv0_and_selling, 1e9, np.maximum(0, min_safety_days - coverage))
    if flag_name == "overstock_flag":
        return np.maximum(0, coverage - overstock_days)
    if flag_name == "low_history_flag":
        hw = df.get("history_weeks", 0).fillna(0)
        hu = df.get("history_units", 0).fillna(0)
        gap_w = np.maximum(0, threshold_weeks - hw)
        gap_u = np.maximum(0, threshold_units - hu)
        return gap_w + (gap_u / max(threshold_units, 1.0))
    return pd.Series(0, index=df.index)

def generate_store_item_actions(fact_kpi: pd.DataFrame, kpi_rules: dict, action_map: dict) -> pd.DataFrame:
    """
    Generate store-item actions (top N) driven by flag_actions dictionary.
    Output: store_item_actions table for execution.
    """
    print("\n[GENERATING STORE-ITEM ACTIONS]")

    flag_actions = action_map.get("flag_actions", {})
    if not flag_actions:
        print("  ⚠️  No flag_actions found in action_map; skipping.")
        return pd.DataFrame()

    pr_rank = action_map.get("priority_rank", DEFAULT_ACTION_MAP["priority_rank"])
    downrank_low_conf = bool(action_map.get("downrank_low_confidence", True))
    top_n = int(action_map.get("store_item_actions_top_n", 50))

    frames = []
    for flag_name, spec in flag_actions.items():
        if flag_name not in fact_kpi.columns:
            continue

        df_flag = fact_kpi[fact_kpi[flag_name] == 1].copy()
        if df_flag.empty:
            continue

        priority = str(spec.get("priority", "MEDIUM")).upper()
        df_flag["flag_name"] = flag_name
        df_flag["owner"] = " / ".join(spec.get("owner", [])) if isinstance(spec.get("owner"), list) else str(spec.get("owner", ""))
        df_flag["action"] = str(spec.get("action", "")).strip()
        df_flag["priority"] = priority
        df_flag["priority_rank"] = int(pr_rank.get(priority, 99))
        df_flag["severity_score"] = _compute_severity(df_flag, flag_name, kpi_rules)

        # Downrank low confidence for sorting (except low_history_flag which is explicitly about confidence)
        df_flag["priority_rank_adj"] = df_flag["priority_rank"]
        if downrank_low_conf and "kpi_confidence" in df_flag.columns and flag_name != "low_history_flag":
            df_flag.loc[df_flag["kpi_confidence"] == "LOW", "priority_rank_adj"] = np.minimum(df_flag["priority_rank"] + 1, 4)

        # Store templates to format later (after top-N selection)
        df_flag["_rationale_template"] = spec.get("rationale_template", "")
        df_flag["_next_step_template"] = spec.get("next_step_template", "")

        frames.append(df_flag)

    if not frames:
        print("  No store-item actions generated (no flags triggered).")
        return pd.DataFrame()

    actions = pd.concat(frames, ignore_index=True)

    # Sort and keep top N
    actions = actions.sort_values(
        by=["priority_rank_adj", "severity_score", "sellout_units_lw"],
        ascending=[True, False, False],
        kind="mergesort",
    ).head(top_n)

    # Format rationale/next steps for the selected actions only
    def _format_row(row: pd.Series) -> pd.Series:
        ctx = row.to_dict()
        ctx.update(kpi_rules)
        row["rationale"] = safe_format(row.get("_rationale_template", ""), ctx)
        row["next_step"] = safe_format(row.get("_next_step_template", ""), ctx)
        return row

    actions = actions.apply(_format_row, axis=1)

    # Keep a clean column set (execution-ready)
    keep_cols = [
        "priority", "owner", "action", "flag_name",
        "store_id", "client_item_nbr", "week_id",
        "brand", "category", "subcategory",
        "store_tier", "region", "state",
        "sellout_units_lw", "on_hand_units", "coverage_days",
        "sellout_units_ly_yoy", "yoy_growth_pct",
        "history_weeks", "history_units", "history_cv", "kpi_confidence",
        "store_subcategory_weight", "used_subcategory_proxy",
        "severity_score", "rationale", "next_step"
    ]
    keep_cols = [c for c in keep_cols if c in actions.columns]

    actions = actions[keep_cols].reset_index(drop=True)

    print(f"✓ Store-item actions generated: {len(actions):,} (top N={top_n})")
    return actions

def generate_action_rollup(actions_df: pd.DataFrame, group_cols: List[str]) -> pd.DataFrame:
    """Roll up store-item actions for exec summaries."""
    if actions_df is None or actions_df.empty:
        return pd.DataFrame()

    group_cols = [c for c in group_cols if c in actions_df.columns]
    if not group_cols:
        return pd.DataFrame()

    tmp = actions_df.copy()
    tmp["store_item_key"] = tmp["store_id"].astype(str) + "||" + tmp["client_item_nbr"].astype(str)

    roll = (
        tmp.groupby(group_cols + ["priority", "owner", "action", "flag_name"], as_index=False, dropna=False)
        .agg(
            action_rows=("store_item_key", "size"),
            affected_store_items=("store_item_key", "nunique"),
            sellout_units_lw=("sellout_units_lw", "sum"),
            on_hand_units=("on_hand_units", "sum"),
        )
    )

    # Priority ranking for sorting
    pr_map = DEFAULT_ACTION_MAP["priority_rank"]
    roll["priority_rank"] = roll["priority"].map(pr_map).fillna(99).astype(int)

    roll = roll.sort_values(["priority_rank"] + group_cols + ["action_rows"], ascending=[True] + [True]*len(group_cols) + [False])
    roll.drop(columns=["priority_rank"], inplace=True, errors="ignore")
    return roll

def generate_commercial_insights(outputs: Dict[str, pd.DataFrame], actions_rollup_brand: pd.DataFrame, kpi_rules: dict) -> pd.DataFrame:
    """
    Exec-friendly insights:
    - opportunities from by_brand (YoY winners + healthy coverage)
    - risk summaries from action rollup (brand-level)
    """
    print("\n[GENERATING COMMERCIAL INSIGHTS]")

    insights: List[Dict[str, Any]] = []
    coverage_target = float(kpi_rules.get("coverage_target_days", 14))

    # Opportunities from KPI rollup (brand)
    if "by_brand" in outputs and not outputs["by_brand"].empty:
        df = outputs["by_brand"].copy()
        for _, row in df.iterrows():
            brand = row.get("brand", "Unknown")
            yoy = row.get("yoy_growth_pct", np.nan)
            coverage = row.get("coverage_days", np.nan)

            if pd.notna(yoy) and yoy > 10 and pd.notna(coverage):
                if coverage >= coverage_target * 0.8 and coverage <= coverage_target * 3:
                    insights.append({
                        "scope": "brand",
                        "scope_value": brand,
                        "insight_type": "OPPORTUNITY",
                        "owner": "Sales",
                        "action": "Invoice / Expand Allocation",
                        "priority": "HIGH",
                        "reason": f"YoY +{yoy:.1f}% with coverage {coverage:.0f}d (target {coverage_target:.0f}d)",
                    })

    # Risks from actions rollup (brand)
    if actions_rollup_brand is not None and not actions_rollup_brand.empty:
        top_risks = actions_rollup_brand.copy()
        # Keep CRITICAL/HIGH only in insights summary
        top_risks = top_risks[top_risks["priority"].isin(["CRITICAL", "HIGH"])].copy()
        pr_map = DEFAULT_ACTION_MAP["priority_rank"]
        top_risks["priority_rank"] = top_risks["priority"].map(pr_map).fillna(99).astype(int)
        top_risks = top_risks.sort_values(["priority_rank", "action_rows"], ascending=[True, False]).head(25)
        top_risks.drop(columns=["priority_rank"], inplace=True, errors="ignore")

        for _, row in top_risks.iterrows():
            insights.append({
                "scope": "brand",
                "scope_value": row.get("brand", "Unknown"),
                "insight_type": f"RISK - {row.get('flag_name','').upper()}",
                "owner": row.get("owner", ""),
                "action": row.get("action", ""),
                "priority": row.get("priority", ""),
                "reason": f"{int(row.get('affected_store_items',0))} store-items flagged ({int(row.get('action_rows',0))} action rows)",
            })

    insights_df = pd.DataFrame(insights)
    if insights_df.empty:
        print("  No insights generated")
        return insights_df

    priority_order = DEFAULT_ACTION_MAP["priority_rank"]
    insights_df["priority_rank"] = insights_df["priority"].map(priority_order).fillna(99).astype(int)
    insights_df = insights_df.sort_values(["priority_rank", "scope", "scope_value"]).drop(columns=["priority_rank"])
    print(f"✓ Generated {len(insights_df)} insights")
    return insights_df

