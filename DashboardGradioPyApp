def export_to_excel(outputs: Dict[str, pd.DataFrame], filename: str = "kpi_tracking_output.xlsx") -> str:
    filepath = os.path.join(EXPORT_DIR, filename)
    with pd.ExcelWriter(filepath, engine="openpyxl") as writer:
        for sheet_name, df in outputs.items():
            safe_sheet_name = sheet_name[:31]
            df.to_excel(writer, sheet_name=safe_sheet_name, index=False)
    print(f"  ✓ Excel: {filepath}")
    return filepath

def export_to_parquet(outputs: Dict[str, pd.DataFrame], prefix: str = "kpi_tracking") -> List[str]:
    try:
        filepaths: List[str] = []
        for table_name, df in outputs.items():
            filename = f"{prefix}_{table_name}.parquet"
            filepath = os.path.join(EXPORT_DIR, filename)
            df.to_parquet(filepath, index=False, compression="snappy")
            filepaths.append(filepath)
        print(f"  ✓ Parquet: {len(filepaths)} files")
        return filepaths
    except ImportError:
        print("  ⚠️  Parquet skipped (install: pip install pyarrow)")
        return []
    except Exception as e:
        print(f"  ⚠️  Parquet failed: {e}")
        return []

def export_to_csv(outputs: Dict[str, pd.DataFrame], prefix: str = "kpi_tracking") -> List[str]:
    filepaths: List[str] = []
    for table_name, df in outputs.items():
        filename = f"{prefix}_{table_name}.csv"
        filepath = os.path.join(EXPORT_DIR, filename)
        df.to_csv(filepath, index=False, encoding="utf-8-sig")
        filepaths.append(filepath)
    print(f"  ✓ CSV: {len(filepaths)} files")
    return filepaths

def export_all_formats(outputs: Dict[str, pd.DataFrame], export_parquet: bool = False) -> Dict[str, Any]:
    print("\n[EXPORTING RESULTS]")
    excel_path = export_to_excel(outputs)
    csv_paths = export_to_csv(outputs)
    parquet_paths: List[str] = []
    if export_parquet:
        parquet_paths = export_to_parquet(outputs)
    return {"excel": excel_path, "parquet": parquet_paths, "csv": csv_paths}

