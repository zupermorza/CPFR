def load_config(path: str) -> dict:
    if os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as f:
                cfg = json.load(f)
            return {**DEFAULT_CONFIG, **cfg}
        except Exception:
            return DEFAULT_CONFIG.copy()
    return DEFAULT_CONFIG.copy()

def load_json_with_defaults(path: str, defaults: Dict[str, Any]) -> Dict[str, Any]:
    if os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            return {**defaults, **data}
        except Exception:
            return defaults.copy()
    return defaults.copy()

def load_kpi_rules(path: str) -> dict:
    """Load KPI thresholds (config-driven, UI-overridable)"""
    rules = load_json_with_defaults(path, DEFAULT_KPI_RULES)
    # Ensure notes don't break numeric access
    rules.pop("notes", None)
    return rules

def load_action_map(path: str) -> dict:
    """Load action map for KPI/flag ownership + intent."""
    action_map = load_json_with_defaults(path, DEFAULT_ACTION_MAP)
    action_map.pop("notes", None)
    # Merge nested dicts cleanly
    if "priority_rank" not in action_map:
        action_map["priority_rank"] = DEFAULT_ACTION_MAP["priority_rank"]
    if "flag_actions" not in action_map:
        action_map["flag_actions"] = DEFAULT_ACTION_MAP["flag_actions"]
    return action_map

