    df_next4, dup_diag_n4w = aggregate_duplicates(
        df_next4_raw,
        keys=["store_id", "client_item_nbr"],
        policy=dup_policy_n4w,
        numeric_cols=["n4w"]
    )

    if dup_diag_current["dup_rate"] > dup_warn_threshold:
        warnings_list.append(
            f"Current inventory duplicates detected: {dup_diag_current['dup_rate']:.1%} of keys duplicated."
        )
    if dup_diag_n4w["dup_rate"] > dup_warn_threshold:
        warnings_list.append(
            f"N4W sell-out duplicates detected: {dup_diag_n4w['dup_rate']:.1%} of keys duplicated."
        )

    report["duplicate_diagnostics"] = {
        "current": dup_diag_current,
        "n4w": dup_diag_n4w
    }
    
    print(f"  Loaded {len(df_current):,} current inventory records")
    print(f"  Loaded {len(item_lookup):,} items and {len(store_lookup):,} stores")

    print("\nStep 2/5: Enriching data with hierarchy...")
    
    # Two-step item lookup merge to prevent data loss
    _l1_cli, _l2_itm = _build_item_lookups_for_cpfr(item_lookup)
    
    cur_enriched = df_current.copy()
    
    # Step 1: Map client_item_nbr to item_id
    if _l1_cli is not None and not _l1_cli.empty:
        cur_enriched = safe_merge(cur_enriched, _l1_cli, on=["client_item_nbr"], how="left")
        print(f"  Mapped {len(cur_enriched):,} records to item_id")
    
    # Step 2: Add item attributes
    if _l2_itm is not None and not _l2_itm.empty:
        cur_enriched = safe_merge(cur_enriched, _l2_itm, on=["item_id"], how="left")
        print(f"  Added item attributes (brand, level_0, etc.)")
    
    # Add store attributes
    cur_enriched = safe_merge(cur_enriched, store_lookup, on=["store_id"], how="left")
    cur_enriched = normalize_keys(cur_enriched)
    cur_enriched = optimize_dtypes(cur_enriched)
    
    print(f"  Enriched dataset: {len(cur_enriched):,} records with full hierarchy")

    # Apply valid item-trait filter if provided
    valid_path = cfg.get("file_valid_item_trait", "")
    if valid_path and os.path.exists(valid_path):
        valid = read_valid_item_trait_cached(valid_path)
        before = len(cur_enriched)
        cur_enriched = safe_merge(cur_enriched, valid, on=["item_id","store_trait"], how="inner")
        after = len(cur_enriched)
        allowed_keys = cur_enriched[["store_id","client_item_nbr"]].drop_duplicates()
        df_current = safe_merge(df_current, allowed_keys, on=["store_id","client_item_nbr"], how="inner")
        print(f"  Applied Valid Item–Trait filter: kept {after:,} of {before:,} records ({100*after/before:.1f}%)")

    # Apply hierarchy filters
    if any(filters.values()):
        print("  Applying hierarchy filters...")
        before = len(cur_enriched)
        cur_enriched = apply_hierarchy_filters(cur_enriched, filters)
        df_current = apply_hierarchy_filters(df_current, filters)
        after = len(cur_enriched)
        print(f"  Filtered to {after:,} records ({100*after/before:.1f}% of previous)")

    cur_enriched, inventory_diag = compute_inventory_aggregation(cur_enriched)

    inventory_dup_rate = inventory_diag["dup_rate"]
    inventory_dup_path = ""
    if inventory_dup_rate > 0.02:
        warnings_list.append(
            f"Inventory duplicates by item_id detected: {inventory_dup_rate:.1%} of store-item_id keys duplicated."
        )
        inv_path = os.path.join(EXPORT_DIR, "top_inventory_duplicates.csv")
        inventory_diag["top_offenders"].to_csv(inv_path, index=False, encoding="utf-8-sig")
        inventory_dup_path = inv_path

    report["inventory_duplicates"] = inventory_diag

    # Store dataframes for filter options
    dataframes = {
        "cur_enriched": cur_enriched,
        "dup_current_top": dup_diag_current["top_keys"],
        "dup_n4w_top": dup_diag_n4w["top_keys"],
        "dup_inventory_top": inventory_diag["top_offenders"]
    }

    print("\nStep 3/5: Computing KPIs by hierarchy levels...")
    
    # In-stock analysis - separate for each level
    print("  - In-stock metrics (by Store Trait, State, Level_0, Brand, Item)")
    instock_by_levels = compute_instock_by_levels(cur_enriched)
    
    # Inventory alerts
    print("  - Slow movers (by hierarchy levels)")
    slow_by_levels = compute_slow_movers_by_levels(cur_enriched, df_wk5)
    
    print("  - Min/Safety compliance (by hierarchy levels)")
    compliance_by_levels = compute_compliance_by_levels(cur_enriched)
    
    print("  - Overstock detail and inventory split")
    overstock_detail = compute_overstock_detail(cur_enriched)
    inventory_split = compute_inventory_split(cur_enriched)

    # Forecast & Risk
    print("  - Forecast with uplift")
    df_fc = compute_forecast(
        cur_enriched,
        df_next4,
        df_store_subcat,
        uplift_enabled=bool(cfg.get("uplift_enabled", True)),
        uplift_cap_min=float(cfg.get("uplift_cap_min", 0.70)),
        uplift_cap_max=float(cfg.get("uplift_cap_max", 1.50)),
        uplift_method=cfg.get("uplift_method", "cap_ratio_to_median"),
        uplift_benchmark=cfg.get("uplift_benchmark", "trait_median")
    )

    lead_time_wks = float(cfg.get("lead_time_wks", 2))
    buffer_wks = float(cfg.get("buffer_wks", 0.5))
    total_horizon_wks = lead_time_wks + buffer_wks

    # Calculate purchase proposal fields at store-item level
    df_fc["wk_demand"] = (df_fc["fc_final"] / 4.0).clip(lower=0)
    df_fc["total_horizon_wks"] = total_horizon_wks
    df_fc["demand_horizon_units"] = (df_fc["wk_demand"] * total_horizon_wks).clip(lower=0)

    df_fc["inventory_position"] = df_fc["on_hand_agg"]

    history_block_weeks = int(cfg.get("history_block_weeks", 4))
    history_sources = ["sales_last4"]
    optional_history_cols = [c for c in ["n4w_last_year", "ly_n4w"] if c in df_fc.columns]
    history_sources.extend(optional_history_cols)
    history_totals = df_fc[history_sources].copy() if history_sources else pd.DataFrame(index=df_fc.index)

    need_df = compute_additional_needed_units(
        df_fc["demand_horizon_units"],
        df_fc["inventory_position"],
        history_totals,
        history_block_weeks=history_block_weeks,
        total_horizon_wks=total_horizon_wks,
        z_value=float(cfg.get("need_cap_z", 3.0)),
        abs_cap=int(cfg.get("need_cap_abs_units", 1000))
    )
    df_fc["additional_needed_raw"] = need_df["additional_needed_raw"]
    df_fc["additional_needed_units"] = need_df["additional_needed_units"]
    df_fc["need_cap_units"] = need_df["need_cap_units"]
    df_fc["need_capped_flag"] = need_df["need_capped_flag"]

    if df_fc["need_capped_flag"].any():
        warnings_list.append("Need cap applied to one or more rows (see store-item detail).")

    if df_fc.get("uplift_capped_flag", pd.Series(False, index=df_fc.index)).any():
        warnings_list.append("Uplift cap applied to one or more rows (see guardrails summary).")

    uplift_capped_pct = float(df_fc.get("uplift_capped_flag", pd.Series(False, index=df_fc.index)).mean()) * 100
    max_raw_uplift = float(df_fc.get("uplift_raw_store_subcat", pd.Series([1.0])).max())
    max_applied_uplift = float(df_fc.get("uplift_applied_store_subcat", pd.Series([1.0])).max())
    num_need_capped_rows = int(df_fc["need_capped_flag"].sum())

    guardrails_summary = (
        "**Guardrails Summary**\n"
        f"- % rows capped (uplift): {uplift_capped_pct:.1f}%\n"
        f"- Max raw uplift: {max_raw_uplift:.2f}\n"
        f"- Max applied uplift: {max_applied_uplift:.2f}\n"
        f"- Total horizon (weeks): {total_horizon_wks:.2f}\n"
        f"- dup_rate_current_inventory: {inventory_dup_rate:.1%}\n"
        f"- num_inventory_aggregated_rows: {inventory_diag['num_aggregated_rows']}\n"
        f"- num_need_capped_rows: {num_need_capped_rows}\n"
        f"- top_inventory_duplicates_path: {inventory_dup_path or 'n/a'}"
    )

    report["guardrails_summary"] = guardrails_summary
    report["warnings"] = warnings_list
    
    print("  - Forecast aggregation (by hierarchy levels)")
    forecast_by_levels = compute_forecast_by_levels(df_fc)
    
    # Compute inventory KPIs from forecast
    print("  - Inventory KPIs (DOI, Efficiency, Coverage)")
    kpi_by_levels = compute_inventory_kpis_by_levels(df_fc, HIERARCHY_LEVELS, efficiency_base=float(cfg.get('efficiency_base_units', 100.0)))
    
    print("  - Stockout risk analysis (by hierarchy levels)")
    risk_by_levels = compute_risk_by_levels(
        df_fc,
        lead_time_wks=lead_time_wks,
        buffer_wks=buffer_wks,
        total_horizon_wks=total_horizon_wks
    )

    # Distribution
    print("  - Distribution concentration (by hierarchy levels)")
    hhi_by_levels, over_by_levels = compute_distribution_by_levels(df_current, df_store_subcat, item_lookup, store_lookup,
                                                       hhi_threshold=float(cfg.get("hhi_threshold",0.25)),
                                                       share_excess_pp=float(cfg.get("share_excess_pp",20.0)))

    print("\nStep 4/5: Preparing outputs...")
    
    # Prepare output dictionary with all hierarchy levels
    outputs = {}
    
    # In-stock (will be enriched with KPIs)
    for level_col, df in instock_by_levels.items():
        outputs[f"instock_{level_col}"] = df
    
    # Enrich in-stock tables with inventory KPIs
    outputs = enrich_instock_tables_with_kpis(outputs, kpi_by_levels)
    
    # Slow movers
    for level_col, df in slow_by_levels.items():
        outputs[f"slow_{level_col}"] = df
    
    # Compliance
    for level_col, df in compliance_by_levels.items():
        outputs[f"compliance_{level_col}"] = df
    
    # Forecast
    for level_col, df in forecast_by_levels.items():
        outputs[f"forecast_{level_col}"] = df
    
    # Risk
    for level_col, df in risk_by_levels.items():
        outputs[f"risk_{level_col}"] = df
    
    # HHI
    for level_col, df in hhi_by_levels.items():
        outputs[f"hhi_{level_col}"] = df
    
    # Over-concentration
    for level_col, df in over_by_levels.items():
        outputs[f"over_{level_col}"] = df
    
    # New detail outputs
    outputs["overstock_detail"] = overstock_detail
    outputs["inventory_split"] = inventory_split
    
    # Export to CSV
    print("  - Exporting CSV files...")
    paths = []
    
    for key, df in outputs.items():
        if not df.empty:
            fname = f"{key}.csv"
            path = os.path.join(EXPORT_DIR, fname)
            df.to_csv(path, index=False, encoding="utf-8-sig")
            paths.append(path)

    if inventory_dup_path:
        paths.append(inventory_dup_path)
    
    print(f"    ✓ Exported {len(paths)} CSV files")
    
    # Optional: Export store-item detail if requested
    if show_store_item:
        print("  - Exporting store-item detail...")
        
        detail_cols = [
            "store_id","client_item_nbr","item_id","brand","level_0","store_name",
            "state","store_trait","on_hand","on_hand_agg","inventory_aggregated_flag","sales_last4"
        ]
        available_cols = [c for c in detail_cols if c in cur_enriched.columns]
        store_item_detail = cur_enriched[available_cols].copy()

        # Bring in forecast & proposal fields at store-item level
        proposal_cols = [
            "store_id","client_item_nbr","fc_final","fc_final_post_uplift","demand_horizon_units",
            "additional_needed_raw","additional_needed_units",
            "uplift_raw_store_subcat","uplift_applied_store_subcat","uplift_capped_flag",
            "total_horizon_wks","inventory_position",
            "need_cap_units","need_capped_flag"
        ]
        proposal_cols = [c for c in proposal_cols if c in df_fc.columns]
        store_item_detail = safe_merge(store_item_detail, df_fc[proposal_cols], on=["store_id","client_item_nbr"], how="left")

        # Optional: order columns nicely
        desired_order = available_cols + [
            "fc_final","fc_final_post_uplift","demand_horizon_units",
            "additional_needed_raw","additional_needed_units",
            "uplift_raw_store_subcat","uplift_applied_store_subcat","uplift_capped_flag",
            "total_horizon_wks","inventory_position",
            "need_cap_units","need_capped_flag"
        ]
        store_item_detail = store_item_detail[[c for c in desired_order if c in store_item_detail.columns]]

        detail_path = os.path.join(EXPORT_DIR, "store_item_detail.csv")
        store_item_detail.to_csv(detail_path, index=False, encoding="utf-8-sig")
        paths.append(detail_path)
        print(f"    ✓ store_item_detail.csv ({len(store_item_detail):,} rows) with purchase proposal")

    # Generate charts
    print("\nStep 5/5: Generating charts...")
    figs = {}
    print(f"  ✓ Created {len(figs)} analytical charts")
    
    return outputs, paths, figs, dataframes, report

