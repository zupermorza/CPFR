def add_history_metrics(fact: pd.DataFrame, history_metrics: pd.DataFrame) -> pd.DataFrame:
    """Merge store-item history metrics into gold fact (store-item level)."""
    if history_metrics is None or history_metrics.empty:
        fact["history_weeks"] = 0
        fact["history_units"] = 0
        fact["history_cv"] = np.nan
        return fact

    fact = safe_merge(fact, history_metrics, on=["store_id", "client_item_nbr"], how="left")
    if "history_weeks" in fact.columns:
        fact["history_weeks"] = fact["history_weeks"].fillna(0).astype(int)
    else:
        fact["history_weeks"] = 0

    if "history_units" in fact.columns:
        fact["history_units"] = fact["history_units"].fillna(0)
    else:
        fact["history_units"] = 0

    if "history_cv" in fact.columns:
        fact["history_cv"] = fact["history_cv"].replace([np.inf, -np.inf], np.nan)
    else:
        fact["history_cv"] = np.nan

    return fact

def compute_confidence(df: pd.DataFrame, kpi_rules: dict) -> pd.Series:
    """Return kpi_confidence label per row based on multi-week evidence."""
    threshold_weeks = int(kpi_rules.get("new_item_history_threshold_weeks", 4))
    threshold_units = float(kpi_rules.get("low_history_threshold_units", 10))
    high_mult = float(kpi_rules.get("high_confidence_units_multiplier", 3))
    cv_thresh = float(kpi_rules.get("history_volatility_cv_threshold", 1.5))

    low_mask = (df["history_weeks"] < threshold_weeks) | (df["history_units"] < threshold_units)

    # Start as LOW
    conf = pd.Series(np.where(low_mask, "LOW", "MEDIUM"), index=df.index, dtype="object")

    # Upgrade to HIGH when strong evidence and not too volatile
    units_high = df["history_units"] >= (threshold_units * high_mult)
    cv_ok = df["history_cv"].fillna(0) <= cv_thresh
    conf[(~low_mask) & units_high & cv_ok] = "HIGH"

    return conf

def calculate_kpis(fact: pd.DataFrame, kpi_rules: dict) -> pd.DataFrame:
    """Calculate KPIs + flags + confidence (all store-item level; only ACTIVE combos reach here)."""
    print("\n[CALCULATING KPIs + CONFIDENCE]")

    df = fact.copy()

    # Thresholds
    min_safety_days = float(kpi_rules.get("min_safety_stock_days", 7))
    overstock_days = float(kpi_rules.get("overstock_threshold_days", 60))
    low_history_threshold_units = float(kpi_rules.get("low_history_threshold_units", 10))
    min_history_weeks = int(kpi_rules.get("new_item_history_threshold_weeks", 4))

    # 1) YoY Growth % (LW vs same-week LY comparator)
    df["yoy_growth_pct"] = np.where(
        df["sellout_units_ly_yoy"] > 0,
        ((df["sellout_units_lw"] - df["sellout_units_ly_yoy"]) / df["sellout_units_ly_yoy"]) * 100,
        np.nan,
    )

    # 2) Sell-Through %
    df["beginning_inv"] = df["on_hand_units"] + df["sellout_units_lw"]
    df["sellthrough_pct"] = np.where(
        df["beginning_inv"] > 0,
        (df["sellout_units_lw"] / df["beginning_inv"]) * 100,
        np.nan,
    )

    # 3) Coverage Days (simple LW / 7 assumption)
    df["avg_daily_sellout"] = df["sellout_units_lw"] / 7
    df["coverage_days"] = np.where(
        df["avg_daily_sellout"] > 0,
        df["on_hand_units"] / df["avg_daily_sellout"],
        np.nan,
    )

    # 4) Inventory Turns (annualized from LW)
    df["inventory_turns_annual"] = np.where(
        df["on_hand_units"] > 0,
        (df["sellout_units_lw"] * 52) / df["on_hand_units"],
        np.nan,
    )

    # 5) In-Stock
    df["in_stock"] = (df["on_hand_units"] > 0).astype(int)

    # 6) KPI confidence (HIGH/MEDIUM/LOW) using multi-week evidence
    if "history_weeks" not in df.columns:
        df["history_weeks"] = 0
    if "history_units" not in df.columns:
        df["history_units"] = 0.0
    if "history_cv" not in df.columns:
        df["history_cv"] = np.nan

    df["kpi_confidence"] = compute_confidence(df, kpi_rules)

    # 7) Low History Flag (TRUE low evidence, not same-week LY demand)
    df["low_history_flag"] = (
        (df["history_weeks"] < min_history_weeks) | (df["history_units"] < low_history_threshold_units)
    ).astype(int)

    # 8) OOS Risk Flag
    df["oos_risk_flag"] = (
        ((df["sellout_units_lw"] > 0) & (df["on_hand_units"] == 0))
        | (df["coverage_days"] < min_safety_days)
    ).astype(int)

    # 9) Overstock Flag
    df["overstock_flag"] = (df["coverage_days"] > overstock_days).fillna(0).astype(int)

    # Cleanup temp columns
    df.drop(columns=["beginning_inv", "avg_daily_sellout"], inplace=True, errors="ignore")

    print(f"✓ KPIs calculated for {len(df):,} ACTIVE rows")
    print(f"  - kpi_confidence LOW: {(df['kpi_confidence']=='LOW').sum():,}")
    print(f"  - OOS risk flags: {df['oos_risk_flag'].sum():,}")
    print(f"  - Overstock flags: {df['overstock_flag'].sum():,}")

    return df

