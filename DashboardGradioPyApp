def run_engine_paths(cfg: dict, filters: Dict = None, show_store_item: bool = False):
    """Optimized engine with separate hierarchy level aggregations"""
    import time
    start_time = time.time()
    
    if filters is None:
        filters = {}
    
    required = ["file_current","file_wk5","file_next4","file_item_lookup","file_store_lookup"]
    for k in required:
        if not cfg.get(k) or not os.path.exists(cfg[k]):
            raise FileNotFoundError(f"Path not found or missing in config: {k} -> {cfg.get(k)}")

    print("\n=== CPFR Analysis Started ===")
    print("Step 1/5: Loading data files...")
    
    # Use cached readers
    df_current = read_current_cached(cfg["file_current"])
    df_wk5 = read_wk5_cached(cfg["file_wk5"])
    df_next4 = read_next4_cached(cfg["file_next4"])
    
    df_store_subcat = pd.DataFrame()
    if cfg.get("file_store_subcat") and os.path.exists(cfg["file_store_subcat"]):
        df_store_subcat = read_store_subcat_cached(cfg["file_store_subcat"])
    
    item_lookup = read_item_lookup_cached(cfg["file_item_lookup"])
    store_lookup = read_store_lookup_cached(cfg["file_store_lookup"])
    
    print(f"  Loaded {len(df_current):,} current inventory records")
    print(f"  Loaded {len(item_lookup):,} items and {len(store_lookup):,} stores")

    print("\nStep 2/5: Enriching data with hierarchy...")
    cur_enriched = safe_merge(df_current, item_lookup, on=["client_item_nbr"], how="left")
    cur_enriched = safe_merge(cur_enriched, store_lookup, on=["store_id"], how="left")
    cur_enriched = normalize_keys(cur_enriched)
    cur_enriched = optimize_dtypes(cur_enriched)

    # Apply valid item-trait filter if provided
    valid_path = cfg.get("file_valid_item_trait", "")
    if valid_path and os.path.exists(valid_path):
        valid = read_valid_item_trait_cached(valid_path)
        before = len(cur_enriched)
        cur_enriched = safe_merge(cur_enriched, valid, on=["item_id","store_trait"], how="inner")
        after = len(cur_enriched)
        allowed_keys = cur_enriched[["store_id","client_item_nbr"]].drop_duplicates()
        df_current = safe_merge(df_current, allowed_keys, on=["store_id","client_item_nbr"], how="inner")
        print(f"  Applied Valid Item–Trait filter: kept {after:,} of {before:,} records ({100*after/before:.1f}%)")

    # Apply hierarchy filters
    if any(filters.values()):
        print("  Applying hierarchy filters...")
        before = len(cur_enriched)
        cur_enriched = apply_hierarchy_filters(cur_enriched, filters)
        df_current = apply_hierarchy_filters(df_current, filters)
        after = len(cur_enriched)
        print(f"  Filtered to {after:,} records ({100*after/before:.1f}% of previous)")

    # Store dataframes for filter options
    dataframes = {"cur_enriched": cur_enriched}

    print("\nStep 3/5: Computing KPIs by hierarchy levels...")
    
    # In-stock analysis - separate for each level
    print("  - In-stock metrics (by Store Trait, State, Level_0, Brand, Item)")
    instock_by_levels = compute_instock_by_levels(cur_enriched)
    
    # Inventory alerts
    print("  - Slow movers (by hierarchy levels)")
    slow_by_levels = compute_slow_movers_by_levels(cur_enriched, df_wk5)
    
    print("  - Min/Safety compliance (by hierarchy levels)")
    compliance_by_levels = compute_compliance_by_levels(cur_enriched)

    # Forecast & Risk
    print("  - Forecast with uplift")
    df_fc = compute_forecast(cur_enriched, df_next4, df_store_subcat)
    
    print("  - Forecast aggregation (by hierarchy levels)")
    forecast_by_levels = compute_forecast_by_levels(df_fc)
    
    print("  - Stockout risk analysis (by hierarchy levels)")
    risk_by_levels = compute_risk_by_levels(df_fc, 
                                  lead_time_wks=int(cfg.get("lead_time_wks",2)), 
                                  buffer_wks=float(cfg.get("buffer_wks",0.5)))

    # Distribution
    print("  - Distribution concentration (by hierarchy levels)")
    hhi_by_levels, over_by_levels = compute_distribution_by_levels(df_current, df_store_subcat, item_lookup, store_lookup,
                                                       hhi_threshold=float(cfg.get("hhi_threshold",0.25)),
                                                       share_excess_pp=float(cfg.get("share_excess_pp",20.0)))

    print("\nStep 4/5: Preparing outputs...")
    
    # Prepare output dictionary with all hierarchy levels
    outputs = {}
    
    # In-stock
    for level_col, df in instock_by_levels.items():
        outputs[f"instock_{level_col}"] = df
    
    # Slow movers
    for level_col, df in slow_by_levels.items():
        outputs[f"slow_{level_col}"] = df
    
    # Compliance
    for level_col, df in compliance_by_levels.items():
        outputs[f"compliance_{level_col}"] = df
    
    # Forecast
    for level_col, df in forecast_by_levels.items():
        outputs[f"forecast_{level_col}"] = df
    
    # Risk
    for level_col, df in risk_by_levels.items():
        outputs[f"risk_{level_col}"] = df
    
    # HHI
    for level_col, df in hhi_by_levels.items():
        outputs[f"hhi_{level_col}"] = df
    
    # Over-concentration
    for level_col, df in over_by_levels.items():
        outputs[f"over_{level_col}"] = df
    
    # Export to CSV
    print("  - Exporting CSV files...")
    paths = []
    
    for key, df in outputs.items():
        if not df.empty:
            fname = f"{key}.csv"
            path = os.path.join(EXPORT_DIR, fname)
            df.to_csv(path, index=False, encoding="utf-8-sig")
            paths.append(path)
    
    print(f"    ✓ Exported {len(paths)} CSV files")
    
    # Optional: Export store-item detail if requested
    if show_store_item:
        print("  - Exporting store-item detail (this may take longer)...")
        detail_cols = ["store_id", "client_item_nbr", "item_id", "brand", "level_0", "store_name", 
                      "state", "store_trait", "on_hand", "sales_last4"]
        available_cols = [c for c in detail_cols if c in cur_enriched.columns]
        store_item_detail = cur_enriched[available_cols].copy()
        detail_path = os.path.join(EXPORT_DIR, "store_item_detail.csv")
        store_item_detail.to_csv(detail_path, index=False, encoding="utf-8-sig")
        paths.append(detail_path)
        print(f"    ✓ store_item_detail.csv ({len(store_item_detail):,} rows)")

    print("\nStep 5/5: Generating charts...")
    figs = create_enhanced_charts(outputs)
    print(f"  ✓ Generated {len(figs)} chart panels")

    elapsed = time.time() - start_time
    print(f"\n=== Analysis Complete in {elapsed:.1f} seconds ===\n")

    return outputs, paths, figs, dataframes

