@lru_cache(maxsize=1)
def read_dim_item(file: str) -> pd.DataFrame:
    """DIM_ITEM: Item Catalog (grain: client_item_nbr)"""
    print("  Loading DIM_ITEM (item catalog)...")
    df = lower_cols(pd.read_excel(file, engine="openpyxl"))

    rename_map = {
        "item nbr": "client_item_nbr",
        "item desc": "item_desc",
        "item description": "item_desc",
        "subcategory": "subcategory",
        "category": "category",
        "brand": "brand",
        "units per case": "units_per_case",
        "item status": "item_status",
        "launch date": "launch_date",
    }
    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})

    if "client_item_nbr" not in df.columns:
        raise ValueError("DIM_ITEM must have 'client_item_nbr' column")

    df = normalize_keys(df)
    df = df.drop_duplicates(subset=["client_item_nbr"])
    df = optimize_dtypes(df)

    print(f"    ✓ {len(df):,} items loaded")
    return df

