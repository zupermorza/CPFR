@lru_cache(maxsize=1)
def read_f_store_item_ly(file: str) -> pd.DataFrame:
    """
    F_STORE_ITEM_LY: Multi-week Last Year Sell-Out
    Grain: store_id × client_item_nbr × week_id
    NOTE (V3): No filtering happens here. YoY comparator + history windows are derived later.
    """
    print("  Loading F_STORE_ITEM_LY (LY sell-out, multi-week)...")
    df = lower_cols(pd.read_excel(file, engine="openpyxl"))

    rename_map = {
        "store nbr": "store_id",
        "item nbr": "client_item_nbr",
        "week": "week_id",
        "week_id": "week_id",
        "pos qty": "sellout_units_ly",
        "sellout": "sellout_units_ly",
        "sales qty": "sellout_units_ly",
    }
    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})

    required = ["store_id", "client_item_nbr", "week_id", "sellout_units_ly"]
    missing = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"F_STORE_ITEM_LY missing required columns: {missing}")

    df = clip_nonneg(df, ["sellout_units_ly"])
    df = normalize_keys(df)

    df = dedup_sum(df, keys=["store_id", "client_item_nbr", "week_id"], sum_cols=["sellout_units_ly"])
    df = optimize_dtypes(df)

    print(f"    ✓ {len(df):,} store-item-week rows loaded ({df['week_id'].nunique():,} unique weeks)")
    return df

@lru_cache(maxsize=1)
def read_f_store_item_current(file: str, week_id: str = "", as_of_date: str = "") -> pd.DataFrame:
    """F_STORE_ITEM_CURRENT: Current Snapshot (grain: store_id × client_item_nbr)"""
    print("  Loading F_STORE_ITEM_CURRENT (current snapshot)...")
    df = lower_cols(pd.read_excel(file, engine="openpyxl"))

    rename_map = {
        "store nbr": "store_id",
        "item nbr": "client_item_nbr",
        "pos qty": "sellout_units_lw",
        "sellout": "sellout_units_lw",
        "last week sellout": "sellout_units_lw",
        "total inv": "on_hand_units",
        "on hand": "on_hand_units",
        "inventory": "on_hand_units",
        "on order": "on_order_units",
        "week": "week_id",
        "as of date": "as_of_date",
    }
    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})

    required = ["store_id", "client_item_nbr", "sellout_units_lw", "on_hand_units"]
    missing = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"F_STORE_ITEM_CURRENT missing required columns: {missing}")

    df = clip_nonneg(df, ["sellout_units_lw", "on_hand_units", "on_order_units"])
    df = normalize_keys(df)

    # Store-item snapshot => sum duplicated combinations (common in exports)
    df = dedup_sum(df, keys=["store_id", "client_item_nbr"], sum_cols=["sellout_units_lw", "on_hand_units", "on_order_units"])

    # Add time dimension if not present
    if "week_id" not in df.columns and week_id:
        df["week_id"] = str(week_id)
    if "as_of_date" not in df.columns and as_of_date:
        df["as_of_date"] = str(as_of_date)

    df = optimize_dtypes(df)

    print(f"    ✓ {len(df):,} store-item combinations loaded")
    return df

