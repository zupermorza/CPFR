@lru_cache(maxsize=1)
def read_f_active_store_item(file: str) -> pd.DataFrame:
    """
    F_ACTIVE_STORE_ITEM: Active Store-Item Combinations (MANDATORY FILTER)
    Grain: store_id × client_item_nbr

    Data structure:
    - two columns: store_id, client_item_nbr
    - may be headered OR headerless (2 columns starting A1)
    """
    print("  Loading F_ACTIVE_STORE_ITEM (active combinations filter)...")

    # Try headered read first
    df = pd.read_excel(file, engine="openpyxl")
    df = lower_cols(df)

    rename_map = {"store nbr": "store_id", "item nbr": "client_item_nbr"}
    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})

    required = ["store_id", "client_item_nbr"]
    if not all(c in df.columns for c in required):
        # Headerless fallback: exactly 2 columns => assume [store_id, client_item_nbr]
        if df.shape[1] == 2:
            df.columns = required
        else:
            missing = [c for c in required if c not in df.columns]
            raise ValueError(f"F_ACTIVE_STORE_ITEM MUST have columns {required} (or 2-column headerless). Missing: {missing}")

    df = df[required].copy()
    df = normalize_keys(df)
    df = df.drop_duplicates(subset=required)

    print(f"    ✓ {len(df):,} ACTIVE store-item combinations loaded")
    print("    ⚠️  CRITICAL: Only these combinations will appear in KPIs/actions/insights")
    return df

