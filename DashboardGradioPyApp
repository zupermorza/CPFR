def derive_yoy_comparator_df(f_ly_all: pd.DataFrame, current_week_id: str, yoy_week_id_ly: str) -> pd.DataFrame:
    """
    Create a YoY comparator dataframe aligned to the *current* week_id for joining to the gold fact.

    Returns columns:
    - store_id
    - client_item_nbr
    - week_id (current_week_id for join)
    - week_id_ly_yoy (original LY comparator week id)
    - sellout_units_ly_yoy
    """
    if not yoy_week_id_ly:
        return pd.DataFrame(columns=["store_id", "client_item_nbr", "week_id", "week_id_ly_yoy", "sellout_units_ly_yoy"])

    df = f_ly_all[f_ly_all["week_id"] == str(yoy_week_id_ly)].copy()
    if len(df) == 0:
        return pd.DataFrame(columns=["store_id", "client_item_nbr", "week_id", "week_id_ly_yoy", "sellout_units_ly_yoy"])

    df = df.rename(columns={"week_id": "week_id_ly_yoy", "sellout_units_ly": "sellout_units_ly_yoy"})
    df["week_id"] = str(current_week_id)
    df = df[["store_id", "client_item_nbr", "week_id", "week_id_ly_yoy", "sellout_units_ly_yoy"]]
    df = normalize_keys(df)
    df = dedup_sum(df, keys=["store_id", "client_item_nbr", "week_id"], sum_cols=["sellout_units_ly_yoy"])
    return df

def select_history_window(f_ly_all: pd.DataFrame, yoy_week_id_ly: str, history_window_weeks: int) -> pd.DataFrame:
    """
    Best-effort selection of a LY history window for evidence metrics.

    Strategy:
    - If week_id parses as YYYYWW and yoy_week_id_ly parses too:
        select weeks in same LY year with week <= yoy_week, then keep last N weeks.
    - Else:
        keep all weeks (no reliable window).
    """
    if history_window_weeks is None or int(history_window_weeks) <= 0:
        return f_ly_all.copy()

    yw = try_parse_year_week(yoy_week_id_ly) if yoy_week_id_ly else None
    if yw is None:
        return f_ly_all.copy()

    ly_year, ly_week = yw

    # Parse week_id into year/week for filtering
    parsed = f_ly_all["week_id"].apply(lambda x: try_parse_year_week(str(x)))
    mask_valid = parsed.notna()
    if mask_valid.sum() == 0:
        return f_ly_all.copy()

    y = parsed[mask_valid].apply(lambda t: t[0]).astype(int)
    w = parsed[mask_valid].apply(lambda t: t[1]).astype(int)

    tmp = f_ly_all.loc[mask_valid].copy()
    tmp["_year"] = y.values
    tmp["_week"] = w.values

    tmp = tmp[(tmp["_year"] == ly_year) & (tmp["_week"] <= ly_week)].copy()

    if tmp.empty:
        return f_ly_all.copy()

    # Keep last N weeks (by week number)
    weeks_sorted = sorted(tmp["_week"].unique())
    last_weeks = set(weeks_sorted[-int(history_window_weeks):])
    tmp = tmp[tmp["_week"].isin(last_weeks)].copy()
    tmp.drop(columns=["_year", "_week"], inplace=True, errors="ignore")
    return tmp

def compute_history_metrics(f_ly_window: pd.DataFrame) -> pd.DataFrame:
    """
    Compute store-item evidence metrics from a multi-week LY window.

    Outputs:
    - history_weeks: number of distinct week_id present
    - history_units: total units across window
    - history_mean/history_std/history_cv: volatility signal (std/mean)
    """
    if f_ly_window is None or f_ly_window.empty:
        return pd.DataFrame(columns=["store_id", "client_item_nbr", "history_weeks", "history_units", "history_mean", "history_std", "history_cv"])

    weekly = (
        f_ly_window.groupby(["store_id", "client_item_nbr", "week_id"], as_index=False, dropna=False)
        .agg({"sellout_units_ly": "sum"})
    )

    agg = (
        weekly.groupby(["store_id", "client_item_nbr"], as_index=False, dropna=False)
        .agg(
            history_weeks=("week_id", "nunique"),
            history_units=("sellout_units_ly", "sum"),
            history_mean=("sellout_units_ly", "mean"),
            history_std=("sellout_units_ly", "std"),
        )
    )

    agg["history_std"] = agg["history_std"].fillna(0)
    agg["history_cv"] = np.where(agg["history_mean"] > 0, agg["history_std"] / agg["history_mean"], np.nan)

    agg = optimize_dtypes(agg)
    agg = normalize_keys(agg)
    return agg

