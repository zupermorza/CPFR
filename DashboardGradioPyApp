def run_kpi_pipeline(cfg: dict) -> Dict[str, pd.DataFrame]:
    print("\n" + "=" * 60)
    print(f"  {APP_TITLE}")
    print("=" * 60 + "\n")

    kpi_rules = load_kpi_rules(cfg.get("kpi_rules_file", "kpi_rules.json"))
    action_map = load_action_map(cfg.get("action_map_file", "kpi_action_map.json"))

    # Load canonical datasets (5 + active filter)
    print("[LOADING CANONICAL DATASETS]")
    dim_item = read_dim_item(cfg["file_dim_item"])
    dim_store = read_dim_store(cfg["file_dim_store"])

    week_id = str(cfg.get("week_id", "")).strip()
    as_of_date = str(cfg.get("as_of_date", "")).strip()

    # Explicit time semantics
    yoy_week_id_ly = str(cfg.get("yoy_week_id_ly", "")).strip() or compute_default_yoy_week_id_ly(week_id)
    history_window_weeks = int(cfg.get("history_window_weeks", 26))

    f_ly_all = read_f_store_item_ly(cfg["file_f_store_item_ly"])
    f_current = read_f_store_item_current(cfg["file_f_store_item_current"], week_id, as_of_date)
    f_season = read_f_store_subcategory_season(cfg["file_f_store_subcategory_season"])
    f_active = read_f_active_store_item(cfg["file_f_active_store_item"])  # MANDATORY

    # Data profile
    print_data_profile(dim_item, dim_store, f_ly_all, f_current, f_season, f_active, week_id, yoy_week_id_ly)

    # Build YoY comparator aligned to current week_id
    f_ly_yoy = derive_yoy_comparator_df(f_ly_all, current_week_id=week_id, yoy_week_id_ly=yoy_week_id_ly)
    if f_ly_yoy.empty:
        print(f"\n⚠️  YoY comparator week not found in LY file: yoy_week_id_ly={yoy_week_id_ly}")
        print("    YoY KPIs will be NaN/0 depending on denominator.\n")

    # Build history window + metrics
    f_ly_window = select_history_window(f_ly_all, yoy_week_id_ly=yoy_week_id_ly, history_window_weeks=history_window_weeks)
    history_metrics = compute_history_metrics(f_ly_window)

    print(f"\n[HISTORY WINDOW]")
    print(f"  history_window_weeks={history_window_weeks}")
    print(f"  LY window rows: {len(f_ly_window):,} (unique weeks={f_ly_window['week_id'].nunique() if not f_ly_window.empty else 0})")
    print(f"  history_metrics rows (store-items): {len(history_metrics):,}")

    # Build gold fact BASE, then apply mandatory active filter
    fact = build_gold_fact_base(f_current, f_ly_yoy, dim_item, dim_store)
    fact = apply_active_filter(fact, f_active)

    # Merge history metrics AFTER active filter (store-item level)
    fact = add_history_metrics(fact, history_metrics)

    # Calculate KPIs + confidence
    fact_kpi = calculate_kpis(fact, kpi_rules)

    # Apply fallback proxy (low confidence items)
    fact_kpi = apply_fallback_logic(fact_kpi, f_season)

    # Generate KPI rollups
    outputs = generate_kpi_tables(fact_kpi)

    # Generate store-item actions + rollups
    store_item_actions = generate_store_item_actions(fact_kpi, kpi_rules, action_map)
    if not store_item_actions.empty:
        outputs["store_item_actions"] = store_item_actions
        outputs["action_rollup_brand"] = generate_action_rollup(store_item_actions, ["brand"])
        outputs["action_rollup_region"] = generate_action_rollup(store_item_actions, ["region"])
        outputs["action_rollup_store_tier"] = generate_action_rollup(store_item_actions, ["store_tier"])

        # Exec insights
        outputs["commercial_insights"] = generate_commercial_insights(outputs, outputs["action_rollup_brand"], kpi_rules)

    # Export
    export_all_formats(outputs, export_parquet=bool(cfg.get("export_parquet", False)))

    print("\n" + "=" * 60)
    print("  PIPELINE COMPLETE")
    print("=" * 60 + "\n")

    return outputs

