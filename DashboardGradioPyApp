def lower_cols(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = [c.strip().lower() for c in df.columns]
    return df

def optimize_dtypes(df: pd.DataFrame) -> pd.DataFrame:
    """Reduce memory footprint"""
    for col in df.select_dtypes(include=["float64"]).columns:
        df[col] = pd.to_numeric(df[col], downcast="float")
    for col in df.select_dtypes(include=["int64"]).columns:
        df[col] = pd.to_numeric(df[col], downcast="integer")
    return df

def normalize_keys(df: pd.DataFrame) -> pd.DataFrame:
    """Standardize key columns"""
    if "store_id" in df.columns:
        df["store_id"] = df["store_id"].astype(str).str.strip().str.upper()
    if "client_item_nbr" in df.columns:
        df["client_item_nbr"] = df["client_item_nbr"].astype(str).str.strip()
    if "week_id" in df.columns:
        df["week_id"] = df["week_id"].astype(str).str.strip()
    if "week_id_ly_yoy" in df.columns:
        df["week_id_ly_yoy"] = df["week_id_ly_yoy"].astype(str).str.strip()
    return df

def clip_nonneg(df: pd.DataFrame, cols: List[str]) -> pd.DataFrame:
    """Ensure non-negative values"""
    for col in cols:
        if col in df.columns:
            df[col] = df[col].clip(lower=0)
    return df

def dedup_sum(df: pd.DataFrame, keys: List[str], sum_cols: List[str]) -> pd.DataFrame:
    """Deduplicate and aggregate by summing"""
    agg_dict = {c: "sum" for c in sum_cols if c in df.columns}
    return df.groupby(keys, dropna=False, as_index=False, observed=True).agg(agg_dict)

def safe_merge(left: pd.DataFrame, right: pd.DataFrame, on: List[str], how: str = "left") -> pd.DataFrame:
    """Merge with automatic right-side deduplication"""
    right_dedup = right.drop_duplicates(subset=on)
    return pd.merge(left, right_dedup, on=on, how=how)

def digits_only(s: Any) -> str:
    return re.sub(r"\D", "", str(s or ""))

def compute_default_yoy_week_id_ly(current_week_id: str) -> str:
    """
    Best-effort default:
    - If current_week_id contains digits like YYYYWW, return (YYYY-1)WW.
    - Else, if current_week_id contains any digits (e.g., '26' or 'W26'), return current_week_id as-is.
      (This supports retailer week schemas where week_id is week-number-only.)
    - Else return empty (requires config override or calendar bridge).
    """
    d = digits_only(current_week_id)
    if len(d) >= 6:
        year = int(d[:4])
        wk = d[4:]
        return f"{year-1}{wk}"
    if len(d) > 0:
        return str(current_week_id).strip()
    return ""

def try_parse_year_week(week_id: str) -> Optional[tuple[int, int]]:
    """
    Best-effort parse of YYYYWW (or YYYYWWW) after removing non-digits.
    Returns (year, week) or None if parse fails.
    """
    d = digits_only(week_id)
    if len(d) >= 6:
        year = int(d[:4])
        wk = int(d[4:])
        return year, wk
    return None

def safe_format(template: str, context: Dict[str, Any]) -> str:
    """Format templates without hard failures."""
    if not isinstance(template, str) or not template:
        return ""
    try:
        return template.format(**context)
    except Exception:
        return template

