def aggregate_by_dimension(fact_kpi: pd.DataFrame, group_by: List[str]) -> pd.DataFrame:
    """Aggregate KPIs by specified dimensions (recompute KPIs at aggregate level)."""
    agg_dict = {
        # Measures (sum)
        "sellout_units_lw": "sum",
        "on_hand_units": "sum",
        "sellout_units_ly_yoy": "sum",

        # Flags (sum = count)
        "low_history_flag": "sum",
        "oos_risk_flag": "sum",
        "overstock_flag": "sum",

        # In-stock percent
        "in_stock": "mean",
    }

    if not group_by:
        agg = pd.DataFrame({
            "sellout_units_lw": [fact_kpi["sellout_units_lw"].sum()],
            "on_hand_units": [fact_kpi["on_hand_units"].sum()],
            "sellout_units_ly_yoy": [fact_kpi["sellout_units_ly_yoy"].sum()],
            "low_history_flag": [fact_kpi["low_history_flag"].sum()],
            "oos_risk_flag": [fact_kpi["oos_risk_flag"].sum()],
            "overstock_flag": [fact_kpi["overstock_flag"].sum()],
            "in_stock": [fact_kpi["in_stock"].mean()],
        })
    else:
        agg = fact_kpi.groupby(group_by, dropna=False, as_index=False).agg(agg_dict)

    # Recalculate KPIs at aggregated level
    agg["yoy_growth_pct"] = np.where(
        agg["sellout_units_ly_yoy"] > 0,
        ((agg["sellout_units_lw"] - agg["sellout_units_ly_yoy"]) / agg["sellout_units_ly_yoy"]) * 100,
        np.nan,
    )

    agg["beginning_inv"] = agg["on_hand_units"] + agg["sellout_units_lw"]
    agg["sellthrough_pct"] = np.where(
        agg["beginning_inv"] > 0,
        (agg["sellout_units_lw"] / agg["beginning_inv"]) * 100,
        np.nan,
    )

    agg["avg_daily_sellout"] = agg["sellout_units_lw"] / 7
    agg["coverage_days"] = np.where(
        agg["avg_daily_sellout"] > 0,
        agg["on_hand_units"] / agg["avg_daily_sellout"],
        np.nan,
    )

    agg["inventory_turns_annual"] = np.where(
        agg["on_hand_units"] > 0,
        (agg["sellout_units_lw"] * 52) / agg["on_hand_units"],
        np.nan,
    )

    agg["instock_pct"] = (agg["in_stock"] * 100).round(1)

    agg.drop(columns=["beginning_inv", "avg_daily_sellout", "in_stock"], inplace=True, errors="ignore")

    # Round numeric
    for col in agg.select_dtypes(include=[np.number]).columns:
        if "pct" in col or "turns" in col or "coverage" in col:
            agg[col] = agg[col].round(1)
        elif "flag" not in col:
            agg[col] = agg[col].round(0)

    return agg

def generate_kpi_tables(fact_kpi: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """Generate KPI tables at different aggregation levels."""
    print("\n[GENERATING KPI TABLES]")

    outputs: Dict[str, pd.DataFrame] = {}

    outputs["total_company"] = aggregate_by_dimension(fact_kpi, [])
    outputs["total_company"]["level"] = "Total Company"
    print("  ✓ Total Company")

    if "brand" in fact_kpi.columns:
        outputs["by_brand"] = aggregate_by_dimension(fact_kpi, ["brand"])
        print(f"  ✓ By Brand ({len(outputs['by_brand'])} rows)")

    if "category" in fact_kpi.columns:
        outputs["by_category"] = aggregate_by_dimension(fact_kpi, ["category"])
        print(f"  ✓ By Category ({len(outputs['by_category'])} rows)")

    if "subcategory" in fact_kpi.columns:
        outputs["by_subcategory"] = aggregate_by_dimension(fact_kpi, ["subcategory"])
        print(f"  ✓ By Subcategory ({len(outputs['by_subcategory'])} rows)")

    if "store_tier" in fact_kpi.columns:
        outputs["by_store_tier"] = aggregate_by_dimension(fact_kpi, ["store_tier"])
        print(f"  ✓ By Store Tier ({len(outputs['by_store_tier'])} rows)")

    region_col = "region" if "region" in fact_kpi.columns else "state"
    if region_col in fact_kpi.columns:
        outputs[f"by_{region_col}"] = aggregate_by_dimension(fact_kpi, [region_col])
        print(f"  ✓ By {region_col.title()} ({len(outputs[f'by_{region_col}'])} rows)")

    if "brand" in fact_kpi.columns and "store_tier" in fact_kpi.columns:
        outputs["brand_x_tier"] = aggregate_by_dimension(fact_kpi, ["brand", "store_tier"])
        print(f"  ✓ Brand × Tier ({len(outputs['brand_x_tier'])} rows)")

    outputs["store_item_detail"] = fact_kpi.copy()
    print(f"  ✓ Store-Item Detail ({len(outputs['store_item_detail'])} rows)")

    return outputs

