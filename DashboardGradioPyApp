TRAIT_MAP = {9: "BA", 1312: "MIBO", 969: "BAE", 297: "SC"}
SMALL_TRAITS = {"BAE","MIBO"}
HIERARCHY_LEVELS = {
    "store_trait": "Store Trait",
    "state": "State", 
    "level_0": "Level_0",
    "brand": "Brand",
    "item_id": "Item Mattel"
}

def lower_cols(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = [c.strip().lower() for c in df.columns]
    return df

def optimize_dtypes(df: pd.DataFrame) -> pd.DataFrame:
    """Convert to efficient data types to reduce memory usage"""
    for col in df.columns:
        if df[col].dtype == 'object':
            if col in ['store_id', 'client_item_nbr', 'item_id', 'store_trait', 'state', 'brand', 'level_0', 'subcategory']:
                df[col] = df[col].astype('category')
        elif df[col].dtype == 'float64':
            df[col] = pd.to_numeric(df[col], downcast='float')
        elif df[col].dtype == 'int64':
            df[col] = pd.to_numeric(df[col], downcast='integer')
    return df

def normalize_keys(df: pd.DataFrame) -> pd.DataFrame:
    for key in ["store_id","item_id","client_item_nbr"]:
        if key in df.columns:
            df[key] = df[key].astype(str).str.strip()
    if "store_id" in df.columns:
        df["store_id"] = df["store_id"].str.replace(r"\.0$", "", regex=True)
    if "store_trait" in df.columns:
        st = pd.to_numeric(df["store_trait"], errors="coerce")
        mapped = st.map(TRAIT_MAP)
        df["store_trait"] = mapped.fillna(df["store_trait"].astype(str).str.strip())
    return df

def clip_nonneg(df: pd.DataFrame, cols: List[str]) -> pd.DataFrame:
    for c in cols:
        if c in df.columns:
            df[c] = pd.to_numeric(df[c], errors="coerce").fillna(0).clip(lower=0)
    return df

def dedup_sum(df: pd.DataFrame, keys: List[str], sum_cols: List[str], max_cols: List[str] = None) -> pd.DataFrame:
    agg_dict = {c: "sum" for c in sum_cols if c in df.columns}
    if max_cols:
        for c in max_cols:
            if c in df.columns:
                agg_dict[c] = "max"
    return df.groupby(keys, dropna=False, as_index=False, observed=True).agg(agg_dict)

def safe_merge(left: pd.DataFrame, right: pd.DataFrame, on: List[str], how: str = "left") -> pd.DataFrame:
    right_dedup = right.drop_duplicates(on)
    return pd.merge(left, right_dedup, on=on, how=how)

def format_percentages(df: pd.DataFrame) -> pd.DataFrame:
    """Convert decimal percentages to percentage format with 1 decimal"""
    percent_cols = [col for col in df.columns if any(x in col.lower() for x in ['pct', 'percent', 'rate', 'ratio', 'instock'])]
    for col in percent_cols:
        if col in df.columns and pd.api.types.is_numeric_dtype(df[col]):
            df[col] = (df[col] * 100).round(1)
    return df

def round_numeric(df: pd.DataFrame) -> pd.DataFrame:
    """Round all numeric columns to 1 decimal place"""
    numeric_cols = df.select_dtypes(include=[np.number]).columns
    for col in numeric_cols:
        df[col] = df[col].round(1)
    return df

def apply_hierarchy_filters(df: pd.DataFrame, filters: Dict) -> pd.DataFrame:
    """Apply hierarchy filters to dataframe"""
    if df.empty:
        return df
    
    for filter_col, filter_values in filters.items():
        if filter_col in df.columns and filter_values:
            df = df[df[filter_col].isin(filter_values)]
    
    return df

