    print("  Loading F_STORE_SUBCATEGORY_SEASON (seasonal demand)...")
    df = lower_cols(pd.read_excel(file, engine="openpyxl"))

    rename_map = {
        "store nbr": "store_id",
        "subcategory": "subcategory",
        "season": "season",
        "week": "week_id",
        "week_id": "week_id",
        "seasonal sellout": "seasonal_sellout_units",
